# ----------------------------
# Helper: two-panel bubble plot
# ----------------------------
generate_bubble_plot_twopanel <- function(df, title_text, outfile, top_n = 20) {
  if (is.null(df) || nrow(df) == 0) {
    message("No significant terms for ", title_text)
    return(invisible(NULL))
  }

  df2 <- df %>%
    dplyr::arrange(desc(Count)) %>%
    dplyr::slice_head(n = top_n) %>%
    dplyr::mutate(
      GeneRatio_num = sapply(strsplit(GeneRatio, "/"), function(x) {
        as.numeric(x[1]) / as.numeric(x[2])
      }),
      Description = Description
    ) %>%
    dplyr::arrange(Count)

  annot <- ggplot(
    df2,
    aes(
      x = 1,
      y = factor(Description, levels = df2$Description),
      label = Description
    )
  ) +
    geom_text(
      hjust = 1,
      size = 10,
      family = "Helvetica"
    ) +
    scale_y_discrete(limits = rev(df2$Description)) +
    theme_void() +
    theme(
      plot.margin = margin(10, 5, 10, 10)
    ) +
    xlim(0.85, 1)

  bubble <- ggplot(
    df2,
    aes(
      x = GeneRatio_num,
      y = factor(Description, levels = df2$Description),
      size = Count,
      color = -log10(p.adjust)
    )
  ) +
    geom_point(alpha = 0.8) +
    scale_size_continuous(range = c(4, 12)) +
    scale_color_gradientn(
      colors = colorRampPalette(pal_jco("default")(3))(100)
    ) +
    labs(
      title = title_text,
      x = "Gene Ratio",
      y = NULL,
      size = "Gene Count",
      color = "-log10(q-value)"
    ) +
    theme_minimal(base_size = 24, base_family = "Helvetica") +
    theme(
      plot.title = element_text(face = "bold", hjust = 0.5),
      axis.text.y = element_blank(),
      axis.ticks.y = element_blank(),
      axis.title.x = element_text(size = 24, margin = margin(t = 10)),
      axis.text.x = element_text(size = 20),
      plot.margin = margin(10, 30, 10, 0),
      legend.title = element_text(size = 20),
      legend.text = element_text(size = 16),
      panel.grid.major.x = element_line(color = "#cccccc"),
      panel.grid.minor.x = element_blank(),
      panel.grid.major.y = element_line(color = "#dddddd")
    )

  combined <- cowplot::plot_grid(
    annot, bubble,
    nrow = 1,
    rel_widths = c(2, 1),
    align = "h",
    axis = "tb"
  )

  ggsave(
    filename = outfile,
    plot = combined,
    width = 20,
    height = 8,
    units = "in",
    dpi = 300,
    bg = "white"
  )

  message("Saved plot: ", outfile)
}

