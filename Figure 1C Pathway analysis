# ----------------------------
# 5) Helper: map symbols to Entrez IDs and run enrichment
# ----------------------------
run_enrichment <- function(symbols, label) {

  gene_map <- bitr(
    symbols,
    fromType = "SYMBOL",
    toType   = "ENTREZID",
    OrgDb    = org.Mm.eg.db
  )

  mapped   <- gene_map$SYMBOL
  unmapped <- setdiff(symbols, mapped)

  cat("=== ", label, " ===\n", sep = "")
  cat("Total symbols provided: ", length(symbols), "\n")
  cat("Successfully mapped:    ", length(mapped),  "\n")
  cat("Failed to map:          ", length(unmapped), "\n")
  if (length(unmapped) > 0) {
    cat("Unmapped symbols:\n")
    print(unmapped)
  }

  entrez_ids <- unique(gene_map$ENTREZID)
  if (length(entrez_ids) == 0L) {
    warning("No genes could be mapped for ", label, "; skipping enrichment.")
    return(NULL)
  }

  ego <- enrichGO(
    gene          = entrez_ids,
    OrgDb         = org.Mm.eg.db,
    ont           = "BP",
    pAdjustMethod = "BH",
    pvalueCutoff  = 0.05,
    qvalueCutoff  = 0.10,
    readable      = TRUE
  )
  ego_df <- as.data.frame(ego)
  if (nrow(ego_df) > 0) {
    ego_df$Bg         <- as.numeric(sub("/.*", "", ego_df$BgRatio))
    ego_df$RichFactor <- ego_df$Count / ego_df$Bg
  }

  ekegg <- enrichKEGG(
    gene         = entrez_ids,
    organism     = "mmu",
    pvalueCutoff = 0.05
  )

  if (!is.null(ekegg) && nrow(as.data.frame(ekegg)) > 0) {
    ekegg <- setReadable(ekegg, OrgDb = org.Mm.eg.db, keyType = "ENTREZID")
    ekegg_df <- as.data.frame(ekegg)
    ekegg_df$ID         <- sub("^mmu", "", ekegg_df$ID)
    ekegg_df$Bg         <- as.numeric(sub("/.*", "", ekegg_df$BgRatio))
    ekegg_df$RichFactor <- ekegg_df$Count / ekegg_df$Bg
  } else {
    ekegg_df <- data.frame()
  }

  list(
    ego = ego, ego_df = ego_df,
    ekegg = ekegg, ekegg_df = ekegg_df
  )
}

# ----------------------------
# 6) Run enrichment
# ----------------------------
res_PC1 <- run_enrichment(genes_PC1, "PC1")
res_PC2 <- run_enrichment(genes_PC2, "PC2")

# ----------------------------
# 7) Save results and plots
# ----------------------------
save_results <- function(res, label) {
  if (is.null(res)) return(invisible(NULL))

  ego_df   <- res$ego_df
  ekegg_df <- res$ekegg_df

  write.csv(
    ego_df,
    file = file.path(outdir, paste0("GO_BP_", label, ".csv")),
    row.names = FALSE
  )

  write.csv(
    ekegg_df,
    file = file.path(outdir, paste0("KEGG_", label, ".csv")),
    row.names = FALSE
  )

  if (!is.null(ego_df) && nrow(ego_df) > 0) {
    generate_bubble_plot_twopanel(
      df = ego_df,
      title_text = paste("GO Enrichment -", label),
      outfile = file.path(outdir, paste0("GO_BP_", label, "_bubble_twopanel.png")),
      top_n = 20
    )
  }

  if (!is.null(ekegg_df) && nrow(ekegg_df) > 0) {
    generate_bubble_plot_twopanel(
      df = ekegg_df,
      title_text = paste("KEGG Enrichment -", label),
      outfile = file.path(outdir, paste0("KEGG_", label, "_bubble_twopanel.png")),
      top_n = 20
    )
  }
}

