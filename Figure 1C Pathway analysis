# ----------------------------
# 2) Same edgeR normalization and no-summer PCA
# ----------------------------
dge <- DGEList(counts = counts)
keep <- filterByExpr(dge, group = meta$phase)
dge  <- dge[keep, , keep.lib.sizes = FALSE]
dge  <- calcNormFactors(dge, method = "TMM")
logCPM <- cpm(dge, log = TRUE, prior.count = 1)

keep_no_summer <- meta$phase != "summer euthermia" & !is.na(meta$phase)
logCPM_no_summer <- logCPM[, keep_no_summer, drop = FALSE]
meta_no_summer   <- meta[keep_no_summer, , drop = FALSE]

pca_ns <- prcomp(t(logCPM_no_summer), center = TRUE, scale. = TRUE)

