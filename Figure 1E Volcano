check_design <- function(
    design,
    design_name
) {
  missing_group_columns <- setdiff(
    group_levels,
    colnames(design)
  )
  
  if (length(missing_group_columns) > 0) {
    stop(
      design_name,
      " is missing these group coefficients: ",
      paste(missing_group_columns, collapse = ", ")
    )
  }
  
  if (qr(design)$rank < ncol(design)) {
    stop(
      design_name,
      " is not full rank. ",
      "Group and Sex may be completely confounded in the metadata."
    )
  }
  
  invisible(TRUE)
}

check_design(
  design_unadjusted,
  "Unadjusted design"
)

check_design(
  design_sex_adjusted,
  "Sex-adjusted design"
)

