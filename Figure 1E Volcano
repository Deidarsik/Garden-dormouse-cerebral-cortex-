safe_query_biomart <- function(
    dataset_name,
    gene_ids
) {
  
  if (length(gene_ids) == 0) {
    return(
      data.frame(
        Target_gene = character(0),
        queried_gene_biotype = character(0),
        stringsAsFactors = FALSE
      )
    )
  }
  
  tryCatch(
    {
      
      dataset_mart <- useMart(
        biomart = "ensembl",
        dataset = dataset_name,
        host = "https://www.ensembl.org"
      )
      
      queried_info <- getBM(
        attributes = c(
          "ensembl_gene_id",
          "gene_biotype"
        ),
        filters = "ensembl_gene_id",
        values = gene_ids,
        mart = dataset_mart
      )
      
      colnames(queried_info) <- c(
        "Target_gene",
        "queried_gene_biotype"
      )
      
      queried_info %>%
        dplyr::distinct(
          Target_gene,
          .keep_all = TRUE
        )
      
    },
    error = function(e) {
      
      message(
        "Could not query dataset ",
        dataset_name,
        ": ",
        conditionMessage(e)
      )
      
      data.frame(
        Target_gene = character(0),
        queried_gene_biotype = character(0),
        stringsAsFactors = FALSE
      )
    }
  )
}

gs_info <- safe_query_biomart(
  dataset_name = "itridecemlineatus_gene_ensembl",
  gene_ids = gs_ids
)

other_info <- safe_query_biomart(
  dataset_name = "mmusculus_gene_ensembl",
  gene_ids = other_ids
)

gene_info <- dplyr::bind_rows(
  gs_info,
  other_info
) %>%
  dplyr::distinct(
    Target_gene,
    .keep_all = TRUE
  )

if (nrow(gene_info) == 0) {
  warning(
    "No gene-biotype information was returned by Ensembl. ",
    "All significant genes will be classified as unannotated."
  )
  
  gene_info <- data.frame(
    Target_gene = all_target_ids,
    queried_gene_biotype = NA_character_,
    stringsAsFactors = FALSE
  )
}


#############################
# Step 16: Biotype-summary function
#############################

make_biotype_summary <- function(
    results_list,
    gene_info,
    analysis_name,
    output_dir,
    fdr_cutoff
) {
  
  summary_list <- list()
  
  for (contrast_name in names(results_list)) {
    
    message(
      "Processing biotypes for ",
      analysis_name,
      ": ",
      contrast_name
    )
    
    significant_results <- results_list[[contrast_name]] %>%
      dplyr::filter(
        FDR < fdr_cutoff
      ) %>%
      dplyr::distinct(
        GeneID,
        .keep_all = TRUE
      )
    
    if (nrow(significant_results) == 0) {
      
      summary_list[[contrast_name]] <- data.frame(
        Analysis = analysis_name,
        Contrast = contrast_name,
        Total = 0,
        ProteinCoding = 0,
        ProteinCodingPct = 0,
        NonProteinCoding = 0,
        NonProteinCodingPct = 0,
        Unannotated = 0,
        UnannotatedPct = 0,
        stringsAsFactors = FALSE
      )
      
      next
    }
    
    significant_results <- significant_results %>%
      dplyr::left_join(
        gene_info,
        by = "Target_gene"
      ) %>%
      dplyr::mutate(
        Category = dplyr::case_when(
          is.na(queried_gene_biotype) ~ "Unannotated",
          queried_gene_biotype == "protein_coding" ~ "Protein coding",
          TRUE ~ "Non protein coding"
        )
      )
    
    total_genes <- nrow(
      significant_results
    )
    
    protein_coding_count <- sum(
      significant_results$Category == "Protein coding"
    )
    
    non_protein_coding_count <- sum(
      significant_results$Category == "Non protein coding"
    )
    
    unannotated_count <- sum(
      significant_results$Category == "Unannotated"
    )
    
    summary_list[[contrast_name]] <- data.frame(
      Analysis = analysis_name,
      Contrast = contrast_name,
      Total = total_genes,
      ProteinCoding = protein_coding_count,
      ProteinCodingPct = round(
        100 * protein_coding_count / total_genes,
        2
      ),
      NonProteinCoding = non_protein_coding_count,
      NonProteinCodingPct = round(
        100 * non_protein_coding_count / total_genes,
        2
      ),
      Unannotated = unannotated_count,
      UnannotatedPct = round(
        100 * unannotated_count / total_genes,
        2
      ),
      stringsAsFactors = FALSE
    )
  }
  
  summary_df <- dplyr::bind_rows(
    summary_list
  )
  
  write.table(
    summary_df,
    file = file.path(
      output_dir,
      paste0(
        "significant_gene_annotation_summary_FDR_lt_",
        fdr_label,
        ".txt"
      )
    ),
    sep = "\t",
    quote = FALSE,
    row.names = FALSE
  )
  
  return(
    summary_df
  )
}


