  paste0(
    "gene_stats_filtered_robust_QL_FDR_",
    fdr_label
  )
)

unadjusted_output_dir <- file.path(
  output_root_path,
  "01_filtered_robust_unadjusted"
)

sex_adjusted_output_dir <- file.path(
  output_root_path,
  "02_filtered_robust_sex_adjusted"
)

comparison_output_dir <- file.path(
  output_root_path,
