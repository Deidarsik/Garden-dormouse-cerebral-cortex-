##############################
# gene_stats_filtered_robust_QL_with_sex_adjustment.R
#
# Main analysis:
#   - filterByExpr()
#   - TMM normalization
#   - robust edgeR quasi-likelihood model
#   - FDR < 0.01
#
# Two analyses are run separately:
#   1. Filtered robust unadjusted model: ~ 0 + Group
#   2. Filtered robust sex-adjusted model: ~ 0 + Group + Sex
#
# The volcano-plot appearance is kept the same as in the original script:
#   - same JAMA palette
#   - same titles and subtitles
#   - same axis labels and shared scales
#   - same multi-panel arrangement
#   - same PDF dimensions
#
# IMPORTANT:
# The exact points and DEG counts will change because low-expression
# filtering is now applied, and the sex-adjusted model is a different model.
#############################


#############################
# Step 0: Paths and settings
#############################

expression_matrix_path <- "/Users/adrian/Desktop/EQU.03/20251016_merged_Cortex_0FPM.txt"
metadata_path          <- "/Users/adrian/Desktop/EQU.03/20251016_merged_Cortex_samples.txt"
gene_annotations_path  <- "/Users/adrian/Desktop/EQU.03/20251016_Equ03_CDS_Mmu_genes.txt"

