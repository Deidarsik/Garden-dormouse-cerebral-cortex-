    ]
  )
  
  significant_in_both <- intersect(
    unadjusted_significant_ids,
    sex_adjusted_significant_ids
  )
  
  lost_after_sex_adjustment <- setdiff(
    unadjusted_significant_ids,
    sex_adjusted_significant_ids
  )
  
  gained_after_sex_adjustment <- setdiff(
    sex_adjusted_significant_ids,
    unadjusted_significant_ids
  )
  
