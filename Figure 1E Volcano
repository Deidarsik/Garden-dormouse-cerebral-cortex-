#############################
# Step 9: Function to define the same contrasts
#############################

make_contrast_matrix <- function(design) {
  makeContrasts(
    SE_vs_TE = SE - TE,
    TE_vs_TL = TE - TL,
    TL_vs_AE = TL - AE,
    AE_vs_AL = AE - AL,
    AL_vs_TE = AL - TE,
    AL_vs_SE = AL - SE,
    levels = design
  )
}


#############################
# Step 10: Function to run one complete edgeR model
#############################

run_edger_model <- function(
    dge_input,
    design,
    analysis_name,
    output_dir,
    gene_annotations,
    fdr_cutoff
) {
  
  cat("\n")
  cat("============================================================\n")
  cat("Starting analysis:", analysis_name, "\n")
  cat("============================================================\n")
  
  full_table_dir <- file.path(
    output_dir,
    "full_tables"
  )
  
  significant_table_dir <- file.path(
    output_dir,
    "significant_DEG_tables"
  )
  
  all_gene_list_dir <- file.path(
    output_dir,
    "all_tested_gene_lists"
  )
  
  significant_gene_list_dir <- file.path(
    output_dir,
    "significant_gene_lists"
  )
  
  dir.create(
    full_table_dir,
    recursive = TRUE,
    showWarnings = FALSE
  )
  
  dir.create(
    significant_table_dir,
    recursive = TRUE,
    showWarnings = FALSE
  )
  
  dir.create(
    all_gene_list_dir,
    recursive = TRUE,
    showWarnings = FALSE
  )
  
  dir.create(
    significant_gene_list_dir,
    recursive = TRUE,
    showWarnings = FALSE
  )
  
  contrast_matrix <- make_contrast_matrix(
    design
  )
  
  write.table(
    contrast_matrix,
    file = file.path(
      output_dir,
      "contrast_matrix.txt"
    ),
    sep = "\t",
    quote = FALSE,
    row.names = TRUE,
    col.names = NA
  )
  
  # Robust negative-binomial dispersion estimation. The robust setting here
  # identifies genes that are outliers from the mean NB dispersion trend.
  dge_model <- estimateDisp(
    dge_input,
    design,
    robust = TRUE
  )
  
  # Robust quasi-likelihood fitting. This is the key robust QL step: it uses
  # robust empirical-Bayes moderation of the genewise QL dispersions.
  fit <- glmQLFit(
    dge_model,
    design,
    robust = TRUE
  )
  
  results_list <- list()
  deg_summary_rows <- list()
  
  for (contrast_name in colnames(contrast_matrix)) {
    
    cat(
      "Testing ",
      analysis_name,
      " contrast: ",
      contrast_name,
      "\n",
      sep = ""
    )
    
    res <- glmQLFTest(
      fit,
      contrast = contrast_matrix[, contrast_name]
    )
    
    raw_tab <- topTags(
      res,
      n = Inf
    )$table
    
    raw_tab$GeneID <- rownames(raw_tab)
    rownames(raw_tab) <- NULL
    
    raw_tab <- raw_tab %>%
      dplyr::distinct(
        GeneID,
        .keep_all = TRUE
      ) %>%
      dplyr::mutate(
        negLog10FDR = -log10(
          pmax(
            FDR,
            .Machine$double.xmin
          )
        ),
        Significance = factor(
          dplyr::case_when(
            FDR < fdr_cutoff & logFC > 0 ~ "Upregulated",
            FDR < fdr_cutoff & logFC < 0 ~ "Downregulated",
            TRUE                         ~ "Not significant"
          ),
          levels = c(
            "Downregulated",
            "Not significant",
            "Upregulated"
          )
        )
      )
    
    # Annotation is added before storing results_list so Target_gene is
    # available for the later biotype analysis.
    annotated_tab <- raw_tab %>%
      dplyr::left_join(
        gene_annotations,
        by = "GeneID"
      )
    
    if (nrow(annotated_tab) != nrow(raw_tab)) {
      stop(
        "Annotation joining changed the number of rows for contrast ",
        contrast_name,
        ". Check duplicated GeneIDs in the annotation file."
      )
    }
    
    significant_tab <- annotated_tab %>%
      dplyr::filter(
        FDR < fdr_cutoff
      )
    
    all_gene_ids <- unique(
      annotated_tab$GeneID[
        !is.na(annotated_tab$GeneID) &
          annotated_tab$GeneID != ""
      ]
    )
    
    significant_gene_ids <- unique(
      significant_tab$GeneID[
        !is.na(significant_tab$GeneID) &
          significant_tab$GeneID != ""
      ]
    )
    
    write.table(
      annotated_tab,
      file = file.path(
        full_table_dir,
        paste0(
          contrast_name,
          "_differential_expression.txt"
        )
      ),
      sep = "\t",
      quote = FALSE,
      row.names = FALSE,
      na = ""
    )
    
    write.table(
      significant_tab,
      file = file.path(
        significant_table_dir,
        paste0(
          contrast_name,
          "_significant_DEGs_FDR_lt_",
          fdr_label,
          ".txt"
        )
      ),
      sep = "\t",
      quote = FALSE,
      row.names = FALSE,
      na = ""
    )
    
    write.table(
      all_gene_ids,
      file = file.path(
        all_gene_list_dir,
        paste0(
          contrast_name,
          "_all_tested_genes.txt"
        )
      ),
      quote = FALSE,
      row.names = FALSE,
      col.names = FALSE
    )
    
    write.table(
      significant_gene_ids,
      file = file.path(
        significant_gene_list_dir,
        paste0(
          contrast_name,
          "_significant_genes_FDR_lt_",
          fdr_label,
          ".txt"
        )
      ),
      quote = FALSE,
      row.names = FALSE,
      col.names = FALSE
    )
    
    up_count <- sum(
      raw_tab$Significance == "Upregulated",
      na.rm = TRUE
    )
    
    down_count <- sum(
      raw_tab$Significance == "Downregulated",
      na.rm = TRUE
    )
    
    deg_summary_rows[[contrast_name]] <- data.frame(
      Analysis = analysis_name,
      Contrast = contrast_name,
      Upregulated = up_count,
      Downregulated = down_count,
      Total_DEGs = up_count + down_count,
      Genes_tested = nrow(raw_tab),
      FDR_cutoff = fdr_cutoff,
      stringsAsFactors = FALSE
    )
    
    # Store the annotated per-gene result table.
    results_list[[contrast_name]] <- annotated_tab
  }
  
  deg_summary <- dplyr::bind_rows(
    deg_summary_rows
  )
  
  write.table(
    deg_summary,
    file = file.path(
      output_dir,
      paste0(
        "DEG_summary_FDR_lt_",
        fdr_label,
        ".txt"
      )
    ),
    sep = "\t",
    quote = FALSE,
    row.names = FALSE
  )
  
  cat("\nDEG summary for", analysis_name, ":\n")
  print(deg_summary)
  
  return(
    list(
      analysis_name = analysis_name,
      dge = dge_model,
      fit = fit,
      design = design,
      contrasts = contrast_matrix,
      results_list = results_list,
      deg_summary = deg_summary
    )
  )
}


#############################
# Step 11: Volcano-plot function
#
# The visual code below retains the original figure style.
#############################

make_volcano_pdf <- function(
    results_list,
    volcano_pdf_path,
    fdr_cutoff
) {
  
  my_colors <- pal_jama("default")(3)
  
  color_values <- c(
    "Downregulated" = my_colors[2],
    "Not significant" = my_colors[1],
    "Upregulated" = my_colors[3]
  )
  
  global_x_min <- min(
    vapply(
      results_list,
      function(df) {
        min(df$logFC, na.rm = TRUE)
      },
      FUN.VALUE = numeric(1)
    )
  )
  
  global_x_max <- max(
    vapply(
      results_list,
      function(df) {
        max(df$logFC, na.rm = TRUE)
      },
      FUN.VALUE = numeric(1)
    )
  )
  
  global_x_range <- global_x_max - global_x_min
  
  global_x_padding <- if (
    is.finite(global_x_range) &&
    global_x_range > 0
  ) {
    0.03 * global_x_range
  } else {
    0.5
  }
  
  global_y_max <- max(
    vapply(
      results_list,
      function(df) {
        finite_y <- df$negLog10FDR[
          is.finite(df$negLog10FDR)
        ]
        
        if (length(finite_y) == 0) {
          return(0)
        }
        
        max(finite_y)
      },
      FUN.VALUE = numeric(1)
    )
  )
  
  global_y_upper <- if (
    is.finite(global_y_max) &&
    global_y_max > 0
  ) {
    1.05 * global_y_max
  } else {
    1
  }
  
  plots_list <- list()
  
  for (contrast_name in names(results_list)) {
    
    results <- results_list[[contrast_name]]
    
    up_count <- sum(
      results$Significance == "Upregulated",
      na.rm = TRUE
    )
    
    down_count <- sum(
      results$Significance == "Downregulated",
      na.rm = TRUE
    )
    
    plot_title <- gsub(
      "_vs_",
      "-",
      contrast_name
    )
    
    subtitle_text <- paste0(
      "<span style='color:",
      color_values["Downregulated"],
      "'>Down: ",
      down_count,
      "</span>",
      "  ",
      "<span style='color:",
      color_values["Upregulated"],
      "'>Up: ",
      up_count,
      "</span>"
    )
    
    p <- ggplot(
      results,
      aes(
        x = logFC,
        y = negLog10FDR,
        color = Significance
      )
    ) +
      geom_point(
        alpha = 0.8,
        size = 2
      ) +
      scale_color_manual(
        values = color_values,
        drop = FALSE
      ) +
      guides(
        color = guide_legend(
          override.aes = list(
            size = 6,
            alpha = 1
          )
        )
      ) +
      labs(
        title = plot_title,
        subtitle = subtitle_text,
        x = "Log Fold Change (log2)",
        y = "-Log10(FDR)",
        color = paste0(
          "Significance (FDR < ",
          fdr_cutoff,
          ")"
        )
      ) +
      scale_x_continuous(
        limits = c(
          global_x_min - global_x_padding,
          global_x_max + global_x_padding
        ),
        expand = c(0, 0)
      ) +
      scale_y_continuous(
        limits = c(
          0,
          global_y_upper
        ),
        expand = c(0, 0)
      ) +
      theme_classic() +
      theme(
        plot.title = element_text(
          size = 16,
          face = "bold",
          hjust = 0.5
        ),
        plot.subtitle = element_markdown(
          size = 14,
          face = "bold",
          hjust = 0.5
        ),
        axis.title = element_text(
          size = 14,
          face = "bold"
        ),
        axis.text = element_text(
          size = 12
        ),
        axis.line = element_line(
          linewidth = 1.2
        ),
        legend.title = element_text(
          size = 16,
          face = "bold"
        ),
        legend.text = element_text(
          size = 14,
          margin = margin(
            t = 5,
            b = 5
          )
        ),
        legend.key.size = grid::unit(
          1.2,
          "cm"
        ),
        legend.spacing.y = grid::unit(
          0.35,
          "cm"
        ),
        legend.key = element_blank()
      )
    
    plots_list[[contrast_name]] <- p
  }
  
  g_legend <- function(a_gplot) {
    
    tmp <- ggplot_gtable(
      ggplot_build(a_gplot)
    )
    
    grob_names <- vapply(
      tmp$grobs,
      function(x) {
        x$name
      },
      FUN.VALUE = character(1)
    )
    
    legend_positions <- grep(
      "^guide-box",
      grob_names
    )
    
    if (length(legend_positions) == 0) {
      return(
        grid::nullGrob()
      )
    }
    
    grob_has_content <- function(grob) {
      
      if (
        is.null(grob) ||
        inherits(
          grob,
          c(
            "zeroGrob",
            "nullGrob"
          )
        )
      ) {
        return(FALSE)
      }
      
      if (
        inherits(grob, "gtable") ||
        !is.null(grob$grobs)
      ) {
        
        if (length(grob$grobs) == 0) {
          return(FALSE)
        }
        
        return(
          any(
            vapply(
              grob$grobs,
              grob_has_content,
              FUN.VALUE = logical(1)
            )
          )
        )
      }
      
      TRUE
    }
    
    populated_positions <- legend_positions[
      vapply(
        tmp$grobs[legend_positions],
        grob_has_content,
        FUN.VALUE = logical(1)
      )
    ]
    
    if (length(populated_positions) == 0) {
      return(
        grid::nullGrob()
      )
    }
    
    tmp$grobs[[populated_positions[1]]]
  }
  
  legend_grob <- g_legend(
    plots_list[[1]]
  )
  
  plots_without_legends <- lapply(
    plots_list,
    function(x) {
      x + theme(
        legend.position = "none"
      )
    }
  )
  
  pdf(
    volcano_pdf_path,
    width = 14,
    height = 10
  )
  
  number_of_plots <- length(
    plots_without_legends
  )
  
  panel_ncol <- ceiling(
    sqrt(number_of_plots)
  )
  
  panel_nrow <- ceiling(
    number_of_plots / panel_ncol
  )
  
  grid.arrange(
    arrangeGrob(
      grobs = plots_without_legends,
      nrow = panel_nrow,
      ncol = panel_ncol
    ),
    legend_grob,
    ncol = 2,
    widths = c(9, 3)
  )
  
  dev.off()
  
  cat(
    "Volcano plots saved in '",
    volcano_pdf_path,
    "'.\n",
    sep = ""
  )
}


