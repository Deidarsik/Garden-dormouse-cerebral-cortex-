      sex_adjusted_significant_ids
    ),
    Significant_in_both = length(
      significant_in_both
    ),
    Lost_after_sex_adjustment = length(
      lost_after_sex_adjustment
    ),
    Gained_after_sex_adjustment = length(
      gained_after_sex_adjustment
    ),
    stringsAsFactors = FALSE
