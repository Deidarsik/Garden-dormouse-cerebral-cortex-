}

# S3: exploratory confidence-bound rankings, built INDEPENDENTLY of each other.
if (run_sensitivity_equivalence) {
  r_eq_stable <- make_priority_ranking(gene_stats$max_contrast_ub, universe,
                                       low_at_top = TRUE, tie_seed = master_seed + 13)
  r_eq_variable <- make_priority_ranking(gene_stats$max_contrast_lb, universe,
                                         low_at_top = FALSE, tie_seed = master_seed + 14)
  eq_a <- run_one_sided_fgsea(
    r_eq_stable, pathways_tested,
    "Sensitivity S3 (EXPLORATORY): low upper confidence bound on the largest stage contrast",
    seed = master_seed + 131)
  eq_b <- run_one_sided_fgsea(
    r_eq_variable, pathways_tested,
    "Sensitivity S3 (EXPLORATORY): high lower confidence bound on the largest stage contrast",
    seed = master_seed + 132)
  eq_a$direction <- "compatible_with_stability"
  eq_b$direction <- "evidence_of_stage_response"
  sens_eq <- rbind(eq_a, eq_b)
  sens_eq$sensitivity_family <- "S3_confidence_bounds_EXPLORATORY"
  sens_eq$padj_sensitivity_family <- p.adjust(sens_eq$pval, method = "BH")
  sens_eq$note <- paste(
    "EXPLORATORY unless prespecified. The two rankings are constructed",
    "independently and are deliberately NOT mirrors: the reverse of an",
    "upper-bound ranking is not a ranking of confidently stage-responsive genes."
  )
  write_out(sens_eq[order(sens_eq$padj_sensitivity_family, sens_eq$pval), ],
            "sensitivity_confidence_bound_results.csv")
  report("S3 exploratory confidence bounds: ",
         sum(sens_eq$padj_sensitivity_family < fdr_cutoff, na.rm = TRUE),
         " significant terms in its own FDR family")
}

# S4: optional exclusion of configured sex-linked symbols. This sensitivity is
