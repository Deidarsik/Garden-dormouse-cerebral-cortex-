# =============================================================================
# 3. ORTHOLOG MAPPING QC AND MOUSE-SYMBOL AGGREGATION
# =============================================================================

hdr("2. Ortholog mapping and mouse-symbol aggregation")

ann <- read.delim(ann_file, header = TRUE, check.names = FALSE,
                  stringsAsFactors = FALSE)
colnames(ann)[1] <- "GeneID"
if (!"Gene_name" %in% colnames(ann)) stop("Annotation file must contain 'Gene_name'.")

ann <- ann[, c("GeneID", "Gene_name")]
ann$GeneID <- trimws(as.character(ann$GeneID))
ann$Gene_name <- trimws(as.character(ann$Gene_name))
ann <- ann[
  !is.na(ann$GeneID) & nzchar(ann$GeneID) &
    !is.na(ann$Gene_name) & nzchar(ann$Gene_name),
]
ann <- unique(ann)

# Everything below is defined ONLY on loci that actually occur in the count
# matrix, so the categories are non-overlapping and can never be negative.
loci_all <- rownames(counts_raw)
ann_in_matrix <- ann[ann$GeneID %in% loci_all, ]

symbols_per_locus <- tapply(ann_in_matrix$Gene_name, ann_in_matrix$GeneID,
                            function(z) length(unique(z)))
ambiguous_loci <- names(symbols_per_locus)[symbols_per_locus > 1]

n_loci_total      <- length(loci_all)
n_loci_with_map   <- length(unique(ann_in_matrix$GeneID))
n_loci_unmapped   <- n_loci_total - n_loci_with_map
n_loci_ambiguous  <- length(ambiguous_loci)
n_loci_unique_map <- n_loci_with_map - n_loci_ambiguous

stopifnot(n_loci_unmapped >= 0, n_loci_ambiguous >= 0, n_loci_unique_map >= 0,
          n_loci_unmapped + n_loci_ambiguous + n_loci_unique_map == n_loci_total)

# Unambiguously mapped loci only.
map_ok <- ann_in_matrix[!ann_in_matrix$GeneID %in% ambiguous_loci, ]
map_ok <- map_ok[!duplicated(map_ok$GeneID), ]

lib_size_all <- colSums(counts_raw)
cpm_all <- edgeR::cpm(counts_raw, lib.size = lib_size_all)
mean_cpm_locus <- rowMeans(cpm_all)
rm(cpm_all)

map_ok$mean_cpm_locus <- mean_cpm_locus[map_ok$GeneID]
loci_per_symbol <- table(map_ok$Gene_name)
map_ok$n_loci_for_symbol <- as.integer(loci_per_symbol[map_ok$Gene_name])

n_symbols_total     <- length(loci_per_symbol)
n_symbols_multi     <- sum(loci_per_symbol > 1)
n_loci_in_multi     <- sum(map_ok$n_loci_for_symbol > 1)

# --- apply the aggregation policy -------------------------------------------
if (!duplicate_symbol_method %in% c("highest_mean_cpm", "sum_counts")) {
  stop("duplicate_symbol_method must be 'highest_mean_cpm' or 'sum_counts'.")
}

if (duplicate_symbol_method == "sum_counts") {
  warning("duplicate_symbol_method = 'sum_counts': counts from all source loci ",
          "sharing a mouse symbol will be summed. This is appropriate ONLY when ",
          "the duplicated rows are fragments or multiple entries of the SAME ",
          "biological source gene. It is NOT appropriate for genuinely distinct ",
          "source paralogues that happen to map to one mouse ortholog.")
  counts_sym <- rowsum(counts_raw[map_ok$GeneID, , drop = FALSE],
                       group = map_ok$Gene_name, reorder = TRUE)
  map_ok$selected_representative <- TRUE
  n_loci_dropped_nonrep <- 0L
} else {
  ord <- order(map_ok$Gene_name, -map_ok$mean_cpm_locus, map_ok$GeneID)
  map_ok <- map_ok[ord, ]
  keep_rep <- !duplicated(map_ok$Gene_name)
  map_ok$selected_representative <- keep_rep
  rep_loci <- map_ok$GeneID[keep_rep]
  counts_sym <- counts_raw[rep_loci, , drop = FALSE]
  rownames(counts_sym) <- map_ok$Gene_name[keep_rep]
  counts_sym <- counts_sym[order(rownames(counts_sym)), , drop = FALSE]
  n_loci_dropped_nonrep <- sum(!keep_rep)
}

qc_dup_map <- data.frame(
  GeneID                 = map_ok$GeneID,
  Gene_name              = map_ok$Gene_name,
  n_loci_for_symbol      = map_ok$n_loci_for_symbol,
  mean_cpm_locus         = round(map_ok$mean_cpm_locus, 4),
  ambiguous_locus        = FALSE,
  selected_representative = map_ok$selected_representative,
  aggregation_policy     = duplicate_symbol_method,
  stringsAsFactors = FALSE
)
