hdr("7. Sensitivity analyses")

run_mirrored_sensitivity <- function(stat, label_low, label_high, tie_seed,
                                     seed_a, seed_b, family_name) {
  r_low  <- make_priority_ranking(stat, universe, low_at_top = TRUE, tie_seed = tie_seed)
  r_high <- reverse_ranking(r_low)
  a <- run_one_sided_fgsea(r_low, pathways_tested, label_low, seed_a)
  b <- run_one_sided_fgsea(r_high, pathways_tested, label_high, seed_b)
  a$direction <- "stable_end"; b$direction <- "variable_end"
  out <- rbind(a, b)
  out$sensitivity_family <- family_name
  out$padj_sensitivity_family <- p.adjust(out$pval, method = "BH")
  out[order(out$padj_sensitivity_family, out$pval), ]
}

if (run_sensitivity_total_variance) {
  sens_total <- run_mirrored_sensitivity(
    gene_stats$total_var_adjusted,
    "Sensitivity S1: low mean-adjusted TOTAL logCPM variance",
    "Sensitivity S1: high mean-adjusted TOTAL logCPM variance",
    tie_seed = master_seed + 11, seed_a = master_seed + 111, seed_b = master_seed + 112,
    family_name = "S1_total_variance_mean_adjusted"
  )
  write_out(sens_total, "sensitivity_total_variance_results.csv")
  report("S1 mean-adjusted total variance: ",
         sum(sens_total$padj_sensitivity_family < fdr_cutoff, na.rm = TRUE),
         " significant terms in its own FDR family")
}

if (run_sensitivity_raw_between_var) {
