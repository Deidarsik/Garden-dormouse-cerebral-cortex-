  n_loci_unmapped                 = n_loci_unmapped,
  n_loci_ambiguous_multi_symbol   = n_loci_ambiguous,
  n_loci_unique_symbol            = n_loci_unique_map,
  n_unique_mouse_symbols          = n_symbols_total,
  n_symbols_with_multiple_loci    = n_symbols_multi,
  n_loci_in_multi_locus_symbols   = n_loci_in_multi,
