# =============================================================================
# 6. EXPLORATORY CONFIDENCE BOUNDS (sensitivity only)
# =============================================================================

max_contrast <- max_contrast_ub <- max_contrast_lb <- rep(NA_real_, length(gene_symbols))
stage_F <- stage_F_p <- rep(NA_real_, length(gene_symbols))

if (run_sensitivity_equivalence) {
  pair_idx <- combn(length(stage_levels), 2)
  cm_pairs <- makeContrasts(
    contrasts = paste0(stage_coef_names[pair_idx[1, ]], "-",
                       stage_coef_names[pair_idx[2, ]]),
    levels = design
  )
  colnames(cm_pairs) <- paste0(stage_levels[pair_idx[1, ]], "_vs_",
                               stage_levels[pair_idx[2, ]])
  fit_pairs <- eBayes(
    contrasts.fit(fit, cm_pairs),
    trend = FALSE,
    robust = TRUE
  )
  
  # Keep every contrast object explicitly two-dimensional. This also handles
  # the two-stage case, where there is only one pairwise contrast.
  lfc <- as.matrix(fit_pairs$coefficients)
  stdev_unscaled <- as.matrix(fit_pairs$stdev.unscaled)
  
  if (!identical(dim(lfc), dim(stdev_unscaled))) {
    stop(
      "Pairwise-contrast coefficient and standard-error matrices have ",
      "incompatible dimensions."
    )
  }
  
  s2_post <- as.numeric(fit_pairs$s2.post)
  df_total <- as.numeric(fit_pairs$df.total)
  
  if (length(s2_post) != nrow(lfc) || length(df_total) != nrow(lfc)) {
    stop(
      "Unexpected empirical-Bayes variance or degrees-of-freedom length in ",
      "the exploratory confidence-bound analysis."
    )
  }
  
  # Gene-specific standard errors and 95% confidence half-widths.
  se <- sweep(
    stdev_unscaled,
    MARGIN = 1,
    STATS = sqrt(s2_post),
    FUN = "*"
  )
  
  tcrit <- qt(
    0.975,
    df = df_total
  )
  
  ci_half_width <- sweep(
    se,
    MARGIN = 1,
    STATS = tcrit,
    FUN = "*"
  )
  
  abs_lfc <- abs(lfc)
  ci_ub <- abs_lfc + ci_half_width
  ci_lb <- abs_lfc - ci_half_width
  
  # Truncate lower confidence limits for |logFC| at zero while preserving the
  # matrix dimensions. Do not use pmax(0, matrix), because pmax() preserves the
  # attributes of its first argument and would drop the matrix dimensions.
  ci_lb[ci_lb < 0] <- 0
  
  max_contrast <- apply(
    abs_lfc,
    1,
    max,
    na.rm = TRUE
  )
  
  max_contrast_ub <- apply(
    ci_ub,
    1,
    max,
    na.rm = TRUE
  )
  
  max_contrast_lb <- apply(
    ci_lb,
    1,
    max,
    na.rm = TRUE
  )
  
  cm_anova <- makeContrasts(
    contrasts = paste0(stage_coef_names[-1], "-", stage_coef_names[1]),
    levels = design
  )
  fit_anova <- eBayes(contrasts.fit(fit, cm_anova), trend = FALSE, robust = TRUE)
  stage_F   <- fit_anova$F
  stage_F_p <- fit_anova$F.p.value
}

