# --- does mean dependence remain? -------------------------------------------
mean_dependence_check <- function(stat, mean_expr, label) {
  ok <- is.finite(stat) & is.finite(mean_expr)
  stat_ok <- stat[ok]
  mean_ok <- mean_expr[ok]
  
  rho <- NA_real_
  trend_frac <- NA_real_
  max_abs_decile <- NA_real_
  decile_range <- NA_real_
  
  if (length(stat_ok) >= 3 && length(unique(stat_ok)) > 1 &&
      length(unique(mean_ok)) > 1) {
    rho <- suppressWarnings(
      cor(stat_ok, mean_ok, method = "spearman", use = "complete.obs")
    )
    
    lf <- tryCatch(
      limma::loessFit(y = stat_ok, x = mean_ok, span = loess_span),
      error = function(e) NULL
    )
    stat_var <- var(stat_ok, na.rm = TRUE)
    if (!is.null(lf) && is.finite(stat_var) && stat_var > 0 &&
        all(is.finite(lf$fitted))) {
      fitted_var <- var(lf$fitted, na.rm = TRUE)
      if (is.finite(fitted_var)) trend_frac <- fitted_var / stat_var
    }
    
    brk <- unique(
      as.numeric(quantile(mean_ok, seq(0, 1, 0.1), na.rm = TRUE))
    )
    if (length(brk) >= 2) {
      dec <- cut(mean_ok, breaks = brk, include.lowest = TRUE,
                 labels = FALSE)
      dec_med <- tapply(stat_ok, dec, median, na.rm = TRUE)
      dec_med <- dec_med[is.finite(dec_med)]
      if (length(dec_med)) {
        max_abs_decile <- max(abs(dec_med), na.rm = TRUE)
        decile_range <- diff(range(dec_med, na.rm = TRUE))
      }
    }
  }
  
  if (!is.finite(rho)) rho <- NA_real_
  if (!is.finite(trend_frac)) trend_frac <- NA_real_
  if (!is.finite(max_abs_decile)) max_abs_decile <- NA_real_
  if (!is.finite(decile_range)) decile_range <- NA_real_
  
  data.frame(
    statistic = label,
    spearman_rho_vs_mean_logCPM = round(rho, 4),
    loess_trend_variance_fraction = round(trend_frac, 5),
    max_abs_decile_median = round(max_abs_decile, 4),
    decile_median_range = round(decile_range, 4),
    stringsAsFactors = FALSE
  )
}

