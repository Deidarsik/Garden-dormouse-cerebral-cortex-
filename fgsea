# --- final internal-consistency checks ---------------------------------------
if (!identical(sort(names(ranks_stable)), sort(names(ranks_variable)))) {
  stop("Primary stable and variable rankings do not contain identical genes.")
}
if (!identical(names(ranks_stable), rev(names(ranks_variable)))) {
  stop("The primary variable ranking is not the exact reverse of the stable ranking.")
}
if (any(ranks_stable <= 0) || any(ranks_variable <= 0) ||
    anyDuplicated(as.numeric(ranks_stable)) ||
    anyDuplicated(as.numeric(ranks_variable))) {
  stop("Primary priority scores must be unique and strictly positive.")
}
if (anyNA(primary_combined$pval) || any(!is.finite(primary_combined$pval))) {
  stop("Primary fgsea results contain missing or non-finite P values.")
}
if (!all(primary_combined$pathway %in% names(pathways_tested))) {
  stop("A primary fgsea result refers to a pathway outside pathways_tested.")
}
expected_primary_sizes <- lengths(pathways_tested[primary_combined$pathway])
if (!all(primary_combined$size == expected_primary_sizes)) {
  stop("At least one primary fgsea pathway size does not match the tested universe.")
}
if (any(!is.finite(primary_combined$padj_primary_global)) ||
    any(primary_combined$padj_primary_global < 0) ||
    any(primary_combined$padj_primary_global > 1)) {
  stop("Joint primary adjusted P values must be finite and between 0 and 1.")
}
if (!all(collapsed_stable$pathway %in%
         fg_stable$pathway[fg_stable$padj_primary_global < fdr_cutoff])) {
  stop("Collapsed stable pathways are not a subset of significant stable pathways.")
}
if (!all(collapsed_variable$pathway %in%
         fg_variable$pathway[fg_variable$padj_primary_global < fdr_cutoff])) {
  stop("Collapsed variable pathways are not a subset of significant variable pathways.")
}

