fdr_axis <- function(p) pmin(-log10(pmax(p, fgsea_eps)), -log10(fgsea_eps))

empty_panel <- function(msg) {
  ggplot() + annotate("text", x = 0, y = 0, label = msg, size = 4) +
    theme_void(base_size = 12)
}

prep_plot_df <- function(df, n_show) {
  if (!nrow(df)) return(df)
  df <- df[order(df$padj_primary_global, df$pval), ]
  df <- head(df, n_show)
  df$label <- clean_go_name(df$pathway)
  df$label <- make.unique(df$label)
  df$neglog10_fdr <- fdr_axis(df$padj_primary_global)
  df$label <- factor(df$label, levels = rev(df$label))
  df
}

single_panel <- function(df, title_text) {
  if (!nrow(df)) return(empty_panel("No terms reached the joint primary FDR threshold."))
  ggplot(df, aes(x = neglog10_fdr, y = label)) +
    geom_segment(aes(x = 0, xend = neglog10_fdr, y = label, yend = label),
                 colour = "grey75") +
    geom_point(aes(size = size), colour = "grey20") +
    geom_vline(xintercept = -log10(fdr_cutoff), linetype = "dashed") +
    scale_size_continuous(name = "Genes in term\n(within universe)") +
    theme_classic(base_size = 11) +
    theme(plot.title = element_text(size = 11)) +
    labs(title = title_text,
         subtitle = paste0("Benjamini-Hochberg adjusted P calculated JOINTLY over ",
                           "the stable and variable primary analyses; dashed line = FDR ",
                           fdr_cutoff, ". Values floored at 1e-", -log10(fgsea_eps), "."),
         x = expression(-log[10]*"(joint primary adjusted P)"),
         y = NULL)
}

