# Adjusted marginal (least-squares) stage means.
#
# With `~ 0 + Stage + SexF`, the raw Stage coefficients are the fitted means at
# the REFERENCE level of sex, not marginal means averaged over the covariate
# distribution. We therefore build an explicit contrast matrix that evaluates
# each stage at the observed mean of every covariate column, which is the
# standard adjusted-marginal-mean construction.
#
# Note that the covariate term added is IDENTICAL for every stage, so it is a
# constant shift common to all stage means. The BETWEEN-STAGE VARIANCE is
# therefore mathematically invariant to this choice; the adjustment matters for
# the reported absolute levels and for interpretability, not for the primary
# statistic. This invariance is verified numerically below.
C_emm <- matrix(0, nrow = length(stage_levels), ncol = ncol(design),
                dimnames = list(stage_levels, colnames(design)))
C_emm[cbind(seq_along(stage_levels), stage_cols)] <- 1
if (length(cov_cols)) {
  C_emm[, cov_cols] <- matrix(colMeans(design[, cov_cols, drop = FALSE]),
                              nrow = length(stage_levels),
                              ncol = length(cov_cols), byrow = TRUE)
}
