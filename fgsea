report("Loci mapped to a unique mouse symbol: ", n_loci_unique_map)
report("Loci with ambiguous mapping (>1 mouse symbol, dropped): ", n_loci_ambiguous)
report("Loci with no mouse mapping (dropped): ", n_loci_unmapped)
