  stop("Metadata lacks the column '", sample_column, "'.")
}
if (!stage_column %in% colnames(meta)) {
  stop("Metadata lacks the column '", stage_column, "'.")
}

# Trim all configured metadata fields before factor construction.
columns_to_trim <- unique(na.omit(c(
