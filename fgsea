}

# --- explicit stage / sex confounding check ---------------------------------
if (has_sex) {
  tab <- table(meta$Stage, meta$SexF)
  sex_per_stage <- rowSums(tab > 0)
  if (all(sex_per_stage == 1)) {
    stop("Stage and sex are completely confounded: every stage contains a single ",
         "sex. Sex cannot be modelled and must not be silently ignored. ",
         "Either restrict the analysis to one sex, or state the confounding ",
         "explicitly and rerun with sex_column <- NA as a documented decision.")
  }
  if (any(sex_per_stage == 1)) {
    message("Note: ", sum(sex_per_stage == 1), " stage(s) contain a single sex. ",
