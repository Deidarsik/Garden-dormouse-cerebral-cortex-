  amb_rows <- ann_in_matrix[ann_in_matrix$GeneID %in% ambiguous_loci, ]
  qc_dup_map <- rbind(qc_dup_map, data.frame(
    GeneID = amb_rows$GeneID,
    Gene_name = amb_rows$Gene_name,
    n_loci_for_symbol = NA_integer_,
    mean_cpm_locus = round(mean_cpm_locus[amb_rows$GeneID], 4),
    ambiguous_locus = TRUE,
    selected_representative = FALSE,
    aggregation_policy = duplicate_symbol_method,
    stringsAsFactors = FALSE
  ))
}
write_out(qc_dup_map, "qc_duplicate_mouse_symbol_mapping.csv")

qc_map_summary <- data.frame(
