}

# Strictly decreasing positive integer priority scores encoding an ordering.
# Ties in the statistic are broken by a SEEDED RANDOM PERMUTATION, never by
# gene name: alphabetical ordering clusters gene families (Olfr*, Rps*, Zfp*)
# that are also co-members of the same GO terms.
make_priority_ranking <- function(stat, genes, low_at_top = TRUE, tie_seed) {
  stopifnot(length(stat) == length(genes), !anyDuplicated(genes), all(is.finite(stat)))
  set.seed(tie_seed)
  tie_key <- sample.int(length(stat))
  ord <- if (low_at_top) order(stat, tie_key) else order(-stat, tie_key)
  setNames(as.numeric(length(ord):1L), genes[ord])
}

# Exact reverse of an existing ranking, ties included. Built from the realised
# order, not by re-sorting the statistic, so the mirror is exact.
reverse_ranking <- function(ranks) {
  g <- rev(names(sort(ranks, decreasing = TRUE)))
  setNames(as.numeric(length(g):1L), g)
}

# Descriptive pathway-rank summary: median position of the set's genes,
# expressed as a percentile of the ranking. 0.5 means no shift.
median_rank_percentile <- function(ranks, genes) {
  n <- length(ranks)
  pos <- rank(-ranks, ties.method = "first")[match(genes, names(ranks))]
  pos <- pos[!is.na(pos)]
  if (!length(pos)) return(NA_real_)
  1 - (median(pos) - 0.5) / n
}

run_one_sided_fgsea <- function(ranks, pathways_tested, label, seed) {
  set.seed(seed)
  res <- fgseaMultilevel(
    pathways    = pathways_tested,
    stats       = ranks,
    minSize     = min_pathway_size,
    maxSize     = max_pathway_size,
    eps         = fgsea_eps,
    scoreType   = "pos",   # one-sided, top-of-list only
    gseaParam   = 0,       # unweighted: gene ORDER only
    nPermSimple = n_perm_simple,
    BPPARAM     = SerialParam()
  )
  res <- as.data.frame(res)
  res$leadingEdge_size <- lengths(res$leadingEdge)
  res$leadingEdge <- vapply(res$leadingEdge, function(z) paste(z, collapse = ";"),
                            character(1))
  res$analysis <- label
  names(res)[names(res) == "padj"] <- "padj_within_run"
  res$median_rank_percentile <- vapply(
    res$pathway, function(p) median_rank_percentile(ranks, pathways_tested[[p]]),
    numeric(1)
  )
  res[order(res$pval), ]
}

# collapsePathways is a REDUNDANCY-REDUCTION procedure, not an inferential test.
# It requires a data.table carrying `pathway` and `ES`, sorted by p-value, and
# its internal machinery reads a column literally named `padj`. Terms are
# SELECTED here by padj_primary_global (the joint primary FDR); the `padj`
# column handed to collapsePathways is populated with that same joint value so
# that selection and collapsing remain consistent. The within-run padj is kept
# elsewhere only as a secondary diagnostic.
collapse_significant <- function(res, ranks, pathways_tested, seed) {
  sig <- res[!is.na(res$padj_primary_global) & res$padj_primary_global < fdr_cutoff, ]
  sig <- sig[order(sig$pval), ]
  if (nrow(sig) == 0) return(character(0))
  dt <- data.table::as.data.table(data.frame(
    pathway = sig$pathway,
    pval    = sig$pval,
    padj    = sig$padj_primary_global,   # joint primary FDR, by design
    ES      = sig$ES,
    NES     = sig$NES,
    size    = sig$size,
    stringsAsFactors = FALSE
  ))
  set.seed(seed)
  out <- tryCatch(
    collapsePathways(fgseaRes = dt, pathways = pathways_tested, stats = ranks,
                     pval.threshold = 0.05, nperm = collapse_nperm, gseaParam = 0),
    error = function(e) {
      warning("collapsePathways() failed (", conditionMessage(e),
              "); reporting the uncollapsed significant set.")
      list(mainPathways = sig$pathway)
    }
  )
  out$mainPathways
}

# cameraPR sensitivity run. `priority_scores` must be the exact realised
# ranking vector used by fgsea, aligned to `gene_names`; HIGH scores correspond
# to the end of the ranking being tested. The inter-gene correlation is a
# specified sensitivity parameter, not an estimate from these data.
run_camerapr <- function(priority_scores, gene_names, pathway_indices,
                         inter_gene_cor = 0.01) {
  if (is.null(names(priority_scores))) {
    stop("cameraPR priority scores must be a named vector.")
  }
  missing_genes <- setdiff(gene_names, names(priority_scores))
  if (length(missing_genes)) {
    stop("cameraPR ranking is missing gene(s): ",
         paste(head(missing_genes, 20), collapse = ", "))
  }
  s <- priority_scores[gene_names]
  if (any(!is.finite(s))) stop("cameraPR ranking contains non-finite scores.")
  
  cam <- limma::cameraPR(
    statistic = s,
    index = pathway_indices,
    use.ranks = TRUE,
    inter.gene.cor = inter_gene_cor,
    sort = FALSE
  )
  cam <- as.data.frame(cam)
  cam$pathway <- rownames(cam)
  rownames(cam) <- NULL
  cam$p_one_sided <- ifelse(
    cam$Direction == "Up",
    cam$PValue / 2,
    1 - cam$PValue / 2
  )
  cam$inter_gene_cor_specified <- inter_gene_cor
  cam[order(cam$p_one_sided),
      c("pathway", "NGenes", "Direction", "PValue", "p_one_sided",
        "inter_gene_cor_specified")]
}

