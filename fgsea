  stop("At least one sample has a zero total library size.")
}
if (!allow_noninteger_counts &&
    !all(abs(counts_raw - round(counts_raw)) < 1e-8)) {
  stop(
    "The count matrix contains non-integer values. edgeR expects raw ",
