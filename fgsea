)

if (!all(c("gs_name", "gene_symbol") %in% colnames(msig))) {
  stop("msigdbr output lacks 'gs_name' / 'gene_symbol'.")
}

pathways_all <- lapply(split(msig$gene_symbol, msig$gs_name), unique)
pathways_in_universe <- lapply(pathways_all, intersect, universe)
size_original <- lengths(pathways_all)
size_universe <- lengths(pathways_in_universe)
tested_flag <- size_universe >= min_pathway_size & size_universe <= max_pathway_size
pathways_tested <- pathways_in_universe[tested_flag]

qc_paths <- data.frame(
  pathway = names(pathways_all),
  size_original = as.integer(size_original),
  size_in_tested_universe = as.integer(size_universe),
  proportion_represented = round(size_universe / pmax(size_original, 1), 4),
