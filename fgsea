  }
}
has_batch <- !is.na(batch_column) && batch_column %in% colnames(meta)
if (has_batch) {
  if (anyNA(meta[[batch_column]]) || any(!nzchar(meta[[batch_column]]))) {
    stop("The configured batch column contains missing or empty values.")
  }
  meta$BatchF <- factor(make.names(meta[[batch_column]]))
  if (nlevels(meta$BatchF) < 2) {
    message("Only one batch level present; batch will not be modelled.")
    has_batch <- FALSE
  }
}
has_animal <- !is.na(animal_column) && animal_column %in% colnames(meta)
