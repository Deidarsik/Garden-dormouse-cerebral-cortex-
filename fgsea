row_vars <- function(x) {
  x <- as.matrix(x)
  if (ncol(x) < 2) return(rep(NA_real_, nrow(x)))
  m <- rowMeans(x)
  rowSums((x - m)^2) / (ncol(x) - 1)
}

write_out <- function(x, filename) {
  x <- as.data.frame(x)
  for (nm in colnames(x)) {
    if (is.list(x[[nm]])) {
      x[[nm]] <- vapply(x[[nm]], function(z) paste(z, collapse = ";"), character(1))
    }
  }
  write.csv(x, file.path(outdir, filename), row.names = FALSE)
  invisible(filename)
}

