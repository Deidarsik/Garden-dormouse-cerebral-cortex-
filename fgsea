if (has_batch) design_terms <- paste(design_terms, "+ BatchF")
design <- model.matrix(as.formula(design_terms), data = meta)
colnames(design) <- make.names(colnames(design))
rownames(design) <- meta[[sample_column]]

design_rank <- qr(design)$rank
if (design_rank < ncol(design)) {
  ne <- limma::nonEstimable(design)
  stop("The design matrix is rank deficient (rank ", design_rank, " < ",
       ncol(design), " coefficients). Non-estimable coefficient(s): ",
       if (is.null(ne)) "unavailable" else paste(ne, collapse = ", "),
       ". This usually means stage is confounded with sex or batch. ",
       "Fix the design explicitly; do not continue silently.")
}
ne_check <- limma::nonEstimable(design)
if (!is.null(ne_check)) {
  stop("Non-estimable coefficient(s) detected: ", paste(ne_check, collapse = ", "))
}

resid_df <- nrow(design) - design_rank
if (resid_df < 1) {
  stop("No residual degrees of freedom (", resid_df, "). Remove covariates.")
}
if (resid_df < 3) {
  warning("Only ", resid_df, " residual degrees of freedom. Empirical Bayes ",
          "moderation will be carrying most of the estimation.")
}

