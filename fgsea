qc_paths <- qc_paths[order(-qc_paths$tested, qc_paths$pathway), ]
write_out(qc_paths, "qc_pathway_coverage.csv")

report("GO:BP terms retrieved: ", length(pathways_all))
report("GO:BP terms testable (size ", min_pathway_size, "-", max_pathway_size,
       " within the universe): ", length(pathways_tested))
if (length(pathways_tested) == 0) stop("No testable GO:BP terms. Check symbol formatting.")

pathway_indices <- limma::ids2indices(pathways_tested, universe, remove.empty = FALSE)

# =============================================================================
# 9. PRIMARY RANKINGS
# =============================================================================

hdr("6. Primary rankings and fgsea")

primary_stat <- gene_stats$between_stage_var_adjusted
tie_seed_primary <- master_seed + 1L

ranks_stable <- make_priority_ranking(primary_stat, universe,
                                      low_at_top = TRUE, tie_seed = tie_seed_primary)
ranks_variable <- reverse_ranking(ranks_stable)

stopifnot(
  identical(sort(names(ranks_stable)), sort(names(ranks_variable))),
  identical(names(ranks_stable), rev(names(ranks_variable))),
  !anyDuplicated(names(ranks_stable)),
  all(ranks_stable > 0), all(ranks_variable > 0),
  !anyDuplicated(as.numeric(ranks_stable))
)

n_exact_ties <- sum(duplicated(primary_stat))
report("Exact ties in the primary statistic: ", n_exact_ties,
       " (resolved by a seeded random permutation, seed ", tie_seed_primary, ")")

rank_table <- function(ranks) {
  idx <- match(names(ranks), gene_stats$Gene_name)
  data.frame(
    Gene_name = names(ranks),
    rank_position = seq_along(ranks),
    priority_score = as.numeric(ranks),
    between_stage_var_adjusted = gene_stats$between_stage_var_adjusted[idx],
    between_stage_var_raw = gene_stats$between_stage_var_raw[idx],
    mean_logCPM = gene_stats$mean_logCPM[idx],
    is_sex_linked = gene_stats$is_sex_linked[idx],
    stringsAsFactors = FALSE
  )
}
write_out(rank_table(ranks_stable), "ranking_primary_stable_first.csv")
write_out(rank_table(ranks_variable), "ranking_primary_variable_first.csv")

# Sex-linked gene QC: positions in the primary ranking. These genes are RETAINED
# in the analysis and adjusted for in the model; this table exists so that any
# influence they have is visible.
sl_tab <- rank_table(ranks_stable)
sl_tab <- sl_tab[sl_tab$is_sex_linked, ]
if (nrow(sl_tab)) {
  sl_tab$percentile_in_stable_ranking <-
    round(sl_tab$rank_position / length(ranks_stable), 4)
}
write_out(sl_tab, "qc_sex_linked_gene_ranks.csv")

# =============================================================================
# 10. PRIMARY fgsea AND JOINT FDR
# =============================================================================

fg_stable <- run_one_sided_fgsea(
  ranks_stable, pathways_tested,
  "Primary: low-to-high adjusted between-stage variance (stable end)",
  seed = master_seed + 101
)
fg_variable <- run_one_sided_fgsea(
  ranks_variable, pathways_tested,
  "Primary: high-to-low adjusted between-stage variance (variable end)",
  seed = master_seed + 102
)
fg_stable$direction   <- "stable_end"
fg_variable$direction <- "variable_end"

# ONE Benjamini-Hochberg correction across the two primary result tables.
# Exploratory sensitivity analyses are never included in this family.
primary_combined <- rbind(fg_stable, fg_variable)
primary_combined$padj_primary_global <- p.adjust(primary_combined$pval, method = "BH")
primary_combined <- primary_combined[order(primary_combined$padj_primary_global,
                                           primary_combined$pval), ]

fg_stable$padj_primary_global <- primary_combined$padj_primary_global[
  match(paste(fg_stable$pathway, "stable_end"),
        paste(primary_combined$pathway, primary_combined$direction))]
fg_variable$padj_primary_global <- primary_combined$padj_primary_global[
  match(paste(fg_variable$pathway, "variable_end"),
        paste(primary_combined$pathway, primary_combined$direction))]

write_out(fg_stable, "fgsea_primary_stable_all.csv")
write_out(fg_variable, "fgsea_primary_variable_all.csv")
write_out(primary_combined, "fgsea_primary_combined_global_FDR.csv")

n_sig_stable   <- sum(fg_stable$padj_primary_global < fdr_cutoff, na.rm = TRUE)
n_sig_variable <- sum(fg_variable$padj_primary_global < fdr_cutoff, na.rm = TRUE)

# =============================================================================
# 11. REDUNDANCY COLLAPSING
# =============================================================================

main_stable <- collapse_significant(fg_stable, ranks_stable, pathways_tested,
                                    seed = master_seed + 201)
main_variable <- collapse_significant(fg_variable, ranks_variable, pathways_tested,
                                      seed = master_seed + 202)

collapsed_stable <- fg_stable[fg_stable$pathway %in% main_stable &
                                fg_stable$padj_primary_global < fdr_cutoff, ]
collapsed_variable <- fg_variable[fg_variable$pathway %in% main_variable &
                                    fg_variable$padj_primary_global < fdr_cutoff, ]
collapsed_stable <- collapsed_stable[order(collapsed_stable$padj_primary_global,
                                           collapsed_stable$pval), ]
collapsed_variable <- collapsed_variable[order(collapsed_variable$padj_primary_global,
                                               collapsed_variable$pval), ]

write_out(collapsed_stable, "fgsea_primary_stable_collapsed.csv")
write_out(collapsed_variable, "fgsea_primary_variable_collapsed.csv")

report("Significant terms at the stable end (joint FDR < ", fdr_cutoff, "): ",
       n_sig_stable, " before collapsing, ", nrow(collapsed_stable), " after")
report("Significant terms at the variable end (joint FDR < ", fdr_cutoff, "): ",
       n_sig_variable, " before collapsing, ", nrow(collapsed_variable), " after")

both_ends <- intersect(collapsed_stable$pathway, collapsed_variable$pathway)
if (length(both_ends)) {
  warning(length(both_ends), " term(s) reach significance at BOTH ends of the ",
          "same ranking and are bimodal; they must not be described as having ",
          "relatively low or relatively high between-stage variance: ",
          paste(head(both_ends, 10), collapse = ", "))
}

