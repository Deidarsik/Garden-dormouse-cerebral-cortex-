# --- mean adjustment ---------------------------------------------------------
# log2(variance + offset) regressed on mean logCPM by loess; the residual is the
# primary statistic. The offset is derived from the data (half the smallest
# strictly positive variance, with a hard floor) so that exactly-zero variances
# are handled without inventing a scale.
make_offset <- function(x) {
  pos <- x[is.finite(x) & x > 0]
  if (!length(pos)) return(1e-10)
  max(1e-10, min(pos) / 2)
}

adjust_for_mean <- function(stat, mean_expr, span = loess_span) {
  if (length(stat) != length(mean_expr)) {
    stop("Mean-adjustment inputs have different lengths.")
  }
  if (length(stat) < 20) {
    stop("Too few genes for a reliable mean-variance loess adjustment.")
  }
  if (any(!is.finite(stat)) || any(stat < 0)) {
    stop("Variance statistic contains negative or non-finite values.")
  }
  if (any(!is.finite(mean_expr))) {
    stop("Mean-expression vector contains non-finite values.")
  }
  if (length(unique(mean_expr)) < 10) {
    stop("Too few unique mean-expression values for loess adjustment.")
  }
  if (!is.finite(span) || span <= 0 || span > 1) {
    stop("loess span must be finite and in the interval (0, 1].")
  }
  
  off <- make_offset(stat)
  y <- log2(stat + off)
  if (any(!is.finite(y))) {
    stop("Log-transformed variance contains non-finite values.")
  }
  
  lf <- tryCatch(
    limma::loessFit(y = y, x = mean_expr, span = span),
    error = function(e) {
      stop("Mean-variance loess fitting failed: ", conditionMessage(e))
    }
  )
  if (length(lf$fitted) != length(stat) ||
      length(lf$residuals) != length(stat)) {
    stop("Mean-variance loess returned vectors of an unexpected length.")
  }
  if (any(!is.finite(lf$fitted)) || any(!is.finite(lf$residuals))) {
    stop("Mean-variance loess returned non-finite fitted values or residuals.")
  }
  
  list(
    offset = off,
    log_stat = y,
    fitted = lf$fitted,
    residual = lf$residuals
  )
}

