report("Stable end: ", n_sig_stable, " significant, ", nrow(collapsed_stable), " after collapsing")
report("Variable end: ", n_sig_variable, " significant, ", nrow(collapsed_variable), " after collapsing")
report("Output directory: ", outdir)
