rownames(counts_df) <- trimws(rownames(counts_df))
colnames(counts_df) <- trimws(colnames(counts_df))
if (nrow(counts_df) == 0) stop("The count matrix contains zero genes.")
if (ncol(counts_df) == 0) stop("The count matrix contains zero samples.")
if (any(!nzchar(rownames(counts_df)))) {
  stop("The count matrix contains empty source-gene identifiers after trimming.")
}
if (any(!nzchar(colnames(counts_df)))) {
  stop("The count matrix contains empty sample identifiers after trimming.")
}
if (anyDuplicated(rownames(counts_df))) {
  stop("The count matrix contains duplicated source-gene row names after trimming.")
}
