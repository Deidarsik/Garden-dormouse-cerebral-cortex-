for (nm in columns_to_trim) {
  meta[[nm]] <- trimws(as.character(meta[[nm]]))
}
if (anyNA(meta[[sample_column]]) || any(!nzchar(meta[[sample_column]]))) {
  stop("Metadata contains missing or empty sample identifiers after trimming.")
}
if (anyNA(meta[[stage_column]]) || any(!nzchar(meta[[stage_column]]))) {
  stop("Metadata contains missing or empty stage values after trimming.")
}
