axis_lab <- function(pc_index, var_pct) {
  paste0("PC", pc_index, " (", var_pct[pc_index], "%)")
}

clean_genes <- function(x) {
  unique(x[!is.na(x) & trimws(x) != "" & trimws(x) != "NA" & trimws(x) != "?"])
}

extract_tissue_from_count <- function(path) {
  x <- basename(path)
  x <- sub("^[0-9]+_merged_", "", x)
  x <- sub("_0FPM.*$", "", x)
  x
}

extract_tissue_from_sample <- function(path) {
  x <- basename(path)
  x <- sub("^[0-9]+_merged_", "", x)
  x <- sub("_samples.*$", "", x)
  x
}

plot_pc12 <- function(df, tissue, var_pct, outfile_png, outfile_pdf) {
  
  # ------------------------------------------------------------
  # Force PC1 and PC2 to use the same numerical axis span.
  # This ensures PC1 is not shorter than PC2.
  # ------------------------------------------------------------
  x_range <- range(df$PC1, na.rm = TRUE)
  y_range <- range(df$PC2, na.rm = TRUE)
  
  x_mid <- mean(x_range)
  y_mid <- mean(y_range)
  
  x_span <- diff(x_range)
  y_span <- diff(y_range)
  
  final_span <- max(x_span, y_span) * 1.10
  
  if (!is.finite(final_span) || final_span == 0) {
    final_span <- 1
  }
  
  x_limits <- x_mid + c(-final_span / 2, final_span / 2)
  y_limits <- y_mid + c(-final_span / 2, final_span / 2)
  
  p <- ggplot(df, aes(x = PC1, y = PC2)) +
    geom_point(
      aes(color = phase, shape = sex),
      size = 5,
      alpha = 0.9,
      stroke = 1.1
    ) +
    scale_color_manual(
      values = ggsci::pal_jco("default")(5),
      drop = FALSE
    ) +
    scale_shape_manual(
      values = c("male" = 16, "female" = 17),
      drop = FALSE
    ) +
    coord_fixed(
      ratio = 1,
      xlim = x_limits,
      ylim = y_limits
    ) +
    labs(
      x = axis_lab(1, var_pct),
      y = axis_lab(2, var_pct),
      color = "Hibernation phase",
      shape = "Sex"
    ) +
    theme_minimal(base_size = 18, base_family = "Helvetica") +
    theme(
      plot.title = element_text(face = "bold", hjust = 0.5),
      axis.title = element_text(size = 18),
      axis.text = element_text(size = 13),
      legend.title = element_text(size = 14),
      legend.text = element_text(size = 12),
      panel.grid.major = element_line(color = "#d9d9d9", linewidth = 0.5),
      panel.grid.minor = element_blank(),
      axis.line = element_line(color = "black"),
      panel.border = element_rect(color = "black", fill = NA, linewidth = 0.8)
    )
  
  ggsave(outfile_png, plot = p, width = 8, height = 6, dpi = 300, bg = "white")
  ggsave(outfile_pdf, plot = p, width = 8, height = 6, bg = "white")
}

generate_bubble_plot_twopanel <- function(df, title_text, outfile, top_n = 20) {
  if (is.null(df) || nrow(df) == 0) {
    message("No significant terms for ", title_text)
    return(invisible(NULL))
  }
  
  df2 <- df %>%
    dplyr::arrange(desc(Count)) %>%
    dplyr::slice_head(n = top_n) %>%
    dplyr::mutate(
      GeneRatio_num = sapply(strsplit(GeneRatio, "/"), function(x) {
        as.numeric(x[1]) / as.numeric(x[2])
      })
    ) %>%
    dplyr::arrange(Count)
  
  desc_levels <- df2$Description
  
  annot <- ggplot(
    df2,
    aes(
      x = 1,
      y = factor(Description, levels = desc_levels),
      label = Description
    )
  ) +
    geom_text(hjust = 1, size = 5, family = "Helvetica") +
    scale_y_discrete(limits = rev(desc_levels)) +
    theme_void() +
    theme(plot.margin = margin(10, 5, 10, 10)) +
    xlim(0.85, 1)
  
  bubble <- ggplot(
    df2,
    aes(
      x = GeneRatio_num,
      y = factor(Description, levels = desc_levels),
      size = Count,
      color = -log10(p.adjust)
    )
  ) +
    geom_point(alpha = 0.8) +
    scale_size_continuous(range = c(4, 12)) +
    scale_color_gradientn(
      colors = colorRampPalette(ggsci::pal_jco("default")(3))(100)
    ) +
    labs(
      title = title_text,
      x = "Gene Ratio",
      y = NULL,
      size = "Gene Count",
      color = "-log10(q-value)"
    ) +
    theme_minimal(base_size = 18, base_family = "Helvetica") +
    theme(
      plot.title = element_text(face = "bold", hjust = 0.5),
      axis.text.y = element_blank(),
      axis.ticks.y = element_blank(),
      axis.title.x = element_text(size = 16, margin = margin(t = 10)),
      axis.text.x = element_text(size = 12),
      plot.margin = margin(10, 30, 10, 0),
      legend.title = element_text(size = 14),
      legend.text = element_text(size = 11),
      panel.grid.major.x = element_line(color = "#cccccc"),
      panel.grid.minor.x = element_blank(),
      panel.grid.major.y = element_line(color = "#dddddd")
    )
  
  combined <- cowplot::plot_grid(
    annot, bubble,
    nrow = 1,
    rel_widths = c(2, 1),
    align = "h",
    axis = "tb"
  )
  
  ggsave(
    filename = outfile,
    plot = combined,
    width = 16,
    height = 8,
    units = "in",
    dpi = 300,
    bg = "white"
  )
}

run_enrichment <- function(symbols, label) {
  if (length(symbols) == 0L) {
    warning("No translated symbols for ", label)
    return(NULL)
  }
  
  gene_map <- suppressMessages(
    tryCatch(
      bitr(
        symbols,
        fromType = "SYMBOL",
        toType   = "ENTREZID",
        OrgDb    = org.Mm.eg.db
      ),
      error = function(e) NULL
    )
  )
  
  if (is.null(gene_map) || nrow(gene_map) == 0L) {
    warning("No genes could be mapped to Entrez IDs for ", label)
    return(NULL)
  }
  
  mapped <- unique(gene_map$SYMBOL)
  unmapped <- setdiff(symbols, mapped)
  entrez_ids <- unique(gene_map$ENTREZID)
  
  cat("=== ", label, " ===\n", sep = "")
  cat("Total symbols provided: ", length(symbols), "\n")
  cat("Successfully mapped:    ", length(mapped), "\n")
  cat("Failed to map:          ", length(unmapped), "\n")
  if (length(unmapped) > 0) {
    cat("Unmapped symbols:\n")
    print(unmapped)
  }
  
  ego <- tryCatch(
    enrichGO(
      gene          = entrez_ids,
      OrgDb         = org.Mm.eg.db,
      ont           = "BP",
      pAdjustMethod = "BH",
      pvalueCutoff  = 0.05,
      qvalueCutoff  = 0.10,
      readable      = TRUE
    ),
    error = function(e) NULL
  )
  
  ego_df <- if (!is.null(ego)) as.data.frame(ego) else data.frame()
  if (nrow(ego_df) > 0) {
    ego_df$Bg <- as.numeric(sub("/.*", "", ego_df$BgRatio))
    ego_df$RichFactor <- ego_df$Count / ego_df$Bg
  }
  
  ekegg <- tryCatch(
    enrichKEGG(
      gene         = entrez_ids,
      organism     = "mmu",
      pvalueCutoff = 0.05
    ),
    error = function(e) NULL
  )
  
  if (!is.null(ekegg) && nrow(as.data.frame(ekegg)) > 0) {
    ekegg <- tryCatch(
      setReadable(ekegg, OrgDb = org.Mm.eg.db, keyType = "ENTREZID"),
      error = function(e) ekegg
    )
    ekegg_df <- as.data.frame(ekegg)
    if ("ID" %in% colnames(ekegg_df)) {
      ekegg_df$ID <- sub("^mmu", "", ekegg_df$ID)
    }
    ekegg_df$Bg <- as.numeric(sub("/.*", "", ekegg_df$BgRatio))
    ekegg_df$RichFactor <- ekegg_df$Count / ekegg_df$Bg
  } else {
    ekegg_df <- data.frame()
  }
  
  list(
    ego = ego,
    ego_df = ego_df,
    ekegg = ekegg,
    ekegg_df = ekegg_df
  )
}

save_enrichment_outputs <- function(res, prefix, tissue_outdir) {
  if (is.null(res)) return(invisible(NULL))
  
  ego_df <- res$ego_df
  ekegg_df <- res$ekegg_df
  
  write.csv(
    ego_df,
    file = file.path(tissue_outdir, paste0("GO_BP_", prefix, ".csv")),
    row.names = FALSE
  )
  
  write.csv(
    ekegg_df,
    file = file.path(tissue_outdir, paste0("KEGG_", prefix, ".csv")),
    row.names = FALSE
  )
  
  if (nrow(ego_df) > 0) {
    generate_bubble_plot_twopanel(
      df = ego_df,
      title_text = paste("GO Enrichment -", prefix),
      outfile = file.path(tissue_outdir, paste0("GO_BP_", prefix, "_bubble.png")),
      top_n = 20
    )
  }
  
  if (nrow(ekegg_df) > 0) {
    generate_bubble_plot_twopanel(
      df = ekegg_df,
      title_text = paste("KEGG Enrichment -", prefix),
      outfile = file.path(tissue_outdir, paste0("KEGG_", prefix, "_bubble.png")),
      top_n = 20
    )
  }
}

