# READ TRANSLATION TABLE
# ============================================================
trans <- read.table(
  trans_file,
  header = TRUE,
  sep = "\t",
  stringsAsFactors = FALSE,
  check.names = FALSE,
  quote = ""
)

colnames(trans) <- trimws(sub("^\\ufeff", "", colnames(trans)))
trans$Source_gene <- trimws(trans$Source_gene)

candidate_symbol_cols <- c(
  "Gene_name.y", "Gene_name", "gene_name", "gene_symbol",
  "SYMBOL", "Symbol", "mouse_symbol", "Mouse_symbol",
  "Mmu_symbol", "external_gene_name"
)

symbol_col <- candidate_symbol_cols[candidate_symbol_cols %in% colnames(trans)][1]

if (is.na(symbol_col) || length(symbol_col) == 0) {
  stop(
    "Could not find a mouse gene symbol column in translation file. Available columns are: ",
    paste(colnames(trans), collapse = ", ")
  )
}

message("Using translation column: ", symbol_col)

# ============================================================
# FIND FILES SAFELY
# ============================================================
all_files <- list.files(base_dir, full.names = TRUE, recursive = FALSE)

count_files <- all_files[
  grepl("_0FPM", basename(all_files)) &
    !grepl("\\.gz$", basename(all_files)) &
    grepl("\\.txt($|-)", basename(all_files))
]

sample_files <- all_files[
  grepl("_samples", basename(all_files)) &
    grepl("\\.txt$", basename(all_files))
]

count_tissues  <- vapply(count_files, extract_tissue_from_count, character(1))
sample_tissues <- vapply(sample_files, extract_tissue_from_sample, character(1))

count_order <- match(count_tissues, preferred_tissue_order)
count_files <- count_files[order(ifelse(is.na(count_order), 999, count_order), count_tissues)]
count_tissues <- vapply(count_files, extract_tissue_from_count, character(1))

sample_order <- match(sample_tissues, preferred_tissue_order)
sample_files <- sample_files[order(ifelse(is.na(sample_order), 999, sample_order), sample_tissues)]
sample_tissues <- vapply(sample_files, extract_tissue_from_sample, character(1))

sample_map <- setNames(sample_files, sample_tissues)

cat("Count files detected:\n")
print(basename(count_files))
cat("\nSample files detected:\n")
print(basename(sample_files))
cat("\nTissues detected in count files:\n")
print(count_tissues)

if (length(count_files) == 0) {
  stop("No count files were detected. Please inspect base_dir and filename patterns.")
}

if (!target_tissue %in% count_tissues) {
  stop(
    "Target tissue '", target_tissue, "' was not found in count files. ",
    "Detected tissues are: ",
    paste(count_tissues, collapse = ", ")
  )
}

summary_rows <- list()

# ============================================================
# MAIN LOOP: CORTEX ONLY
# ============================================================
for (count_file in count_files) {
  tissue <- extract_tissue_from_count(count_file)
  
  # Only run Cortex
  if (tissue != target_tissue) next
  
  message("\n==============================")
  message("Processing tissue: ", tissue)
  
  sample_file <- unname(sample_map[tissue])
  if (is.na(sample_file) || length(sample_file) == 0L) {
    warning("No matching sample file found for tissue: ", tissue)
    next
  }
  
  tissue_outdir <- file.path(outdir, tissue)
  if (!dir.exists(tissue_outdir)) dir.create(tissue_outdir, recursive = TRUE)
  
  counts <- read.table(
    count_file,
    header = TRUE,
    sep = "\t",
    check.names = FALSE,
    stringsAsFactors = FALSE,
    quote = ""
  )
  
  if (!"Gene" %in% colnames(counts)) {
    warning("Skipping ", tissue, ": first column must be named 'Gene'.")
    next
  }
  
  rownames(counts) <- counts$Gene
  counts$Gene <- NULL
  
  if (any(counts %% 1 != 0, na.rm = TRUE)) {
    message("Non-integer counts detected; rounding to nearest integer for edgeR.")
    counts <- round(as.matrix(counts))
  } else {
    counts <- as.matrix(counts)
  }
  storage.mode(counts) <- "numeric"
  
  meta_raw <- read.table(
    sample_file,
    header = TRUE,
    sep = "\t",
    stringsAsFactors = FALSE,
    check.names = FALSE,
    quote = ""
  )
  
  required_cols <- c("Sample", "Animal", "Tissue", "Group", "Sex")
  missing_cols <- setdiff(required_cols, colnames(meta_raw))
  if (length(missing_cols) > 0) {
    warning(
      "Skipping ", tissue, ": sample file missing columns: ",
      paste(missing_cols, collapse = ", ")
    )
    next
  }
  
  idx <- match(colnames(counts), meta_raw$Sample)
  if (any(is.na(idx))) {
    warning(
      "Skipping ", tissue, ": these count columns are not found in metadata: ",
      paste(colnames(counts)[is.na(idx)], collapse = ", ")
    )
    next
  }
  
  meta <- meta_raw[idx, , drop = FALSE]
  
  if (any(meta$Tissue != tissue, na.rm = TRUE)) {
    warning(
      "Tissue mismatch detected in sample file for ", tissue,
      ". Sample metadata tissues found: ",
      paste(unique(meta$Tissue), collapse = ", ")
    )
  }
  
  meta$phase <- phase_map[meta$Group]
  meta$sex   <- ifelse(toupper(meta$Sex) == "M", "male", "female")
  
  meta$phase <- factor(meta$phase, levels = ordered_phases)
  meta$sex   <- factor(meta$sex, levels = c("male", "female"))
  
  rownames(meta) <- meta$Sample
  
  # ============================================================
  # NORMALIZATION
  # ============================================================
  dge <- DGEList(counts = counts)
  keep <- filterByExpr(dge, group = meta$phase)
  dge  <- dge[keep, , keep.lib.sizes = FALSE]
  dge  <- calcNormFactors(dge, method = "TMM")
  logCPM <- cpm(dge, log = TRUE, prior.count = 1)
  
  # ============================================================
  # PCA INCLUDING SUMMER EUTHERMIA
  # ============================================================
  keep_pca <- !is.na(meta$phase)
  
  logCPM_pca <- logCPM[, keep_pca, drop = FALSE]
  meta_pca   <- meta[keep_pca, , drop = FALSE]
  
  if (ncol(logCPM_pca) < 3) {
    warning("Skipping ", tissue, ": fewer than 3 samples available.")
    next
  }
  
  pca_res <- prcomp(t(logCPM_pca), center = TRUE, scale. = TRUE)
  var_expl <- (pca_res$sdev^2) / sum(pca_res$sdev^2)
  var_pct  <- sprintf("%.2f", 100 * var_expl)
  
  score_df <- as.data.frame(pca_res$x)
  score_df$sample <- meta_pca$Sample
  score_df$animal <- meta_pca$Animal
  score_df$phase  <- meta_pca$phase
  score_df$sex    <- meta_pca$sex
  
  # ============================================================
  # PLOT PC1 VS PC2 ONLY
  # ============================================================
  plot_pc12(
    df = score_df,
    tissue = tissue,
    var_pct = var_pct,
    outfile_png = file.path(tissue_outdir, paste0(tissue, "_PCA_PC1_vs_PC2_with_summer.png")),
    outfile_pdf = file.path(tissue_outdir, paste0(tissue, "_PCA_PC1_vs_PC2_with_summer.pdf"))
  )
  
  # ============================================================
  # PC1 AND PC2 LOADINGS + ENRICHMENT
  # ============================================================
  loadings <- as.data.frame(pca_res$rotation)
  loadings$Gene <- rownames(loadings)
  
  n_top <- max(1, ceiling(nrow(loadings) * 0.10))
  
  top_PC1 <- loadings[order(abs(loadings$PC1), decreasing = TRUE), ][1:n_top, , drop = FALSE]
  top_PC2 <- loadings[order(abs(loadings$PC2), decreasing = TRUE), ][1:n_top, , drop = FALSE]
  
  top_PC1_merged <- merge(
    top_PC1,
    trans,
    by.x = "Gene",
    by.y = "Source_gene",
    all.x = TRUE
  )
  
  top_PC2_merged <- merge(
    top_PC2,
    trans,
    by.x = "Gene",
    by.y = "Source_gene",
    all.x = TRUE
  )
  
  write.table(
    top_PC1_merged,
    file.path(tissue_outdir, paste0(tissue, "_Top10pct_PC1_genes_annotated_with_summer.tsv")),
    sep = "\t",
    quote = FALSE,
    row.names = FALSE
  )
  
  write.table(
    top_PC2_merged,
    file.path(tissue_outdir, paste0(tissue, "_Top10pct_PC2_genes_annotated_with_summer.tsv")),
    sep = "\t",
    quote = FALSE,
    row.names = FALSE
  )
  
  genes_PC1 <- clean_genes(top_PC1_merged[[symbol_col]])
  genes_PC2 <- clean_genes(top_PC2_merged[[symbol_col]])
  
  res_PC1 <- run_enrichment(genes_PC1, paste0(tissue, "_PC1_top10pct_with_summer"))
  res_PC2 <- run_enrichment(genes_PC2, paste0(tissue, "_PC2_top10pct_with_summer"))
  
  save_enrichment_outputs(res_PC1, paste0(tissue, "_PC1_top10pct_with_summer"), tissue_outdir)
  save_enrichment_outputs(res_PC2, paste0(tissue, "_PC2_top10pct_with_summer"), tissue_outdir)
  
  summary_rows[[length(summary_rows) + 1L]] <- data.frame(
    Tissue = tissue,
    Count_file = basename(count_file),
    Sample_file = basename(sample_file),
    Samples_total = ncol(counts),
    Samples_used_for_PCA = ncol(logCPM_pca),
    Genes_after_filterByExpr = nrow(logCPM),
    Top10pct_genes = n_top,
    PC1_translated_symbols = length(genes_PC1),
    PC2_translated_symbols = length(genes_PC2),
    PC1_GO_terms = if (is.null(res_PC1)) 0 else nrow(res_PC1$ego_df),
    PC1_KEGG_terms = if (is.null(res_PC1)) 0 else nrow(res_PC1$ekegg_df),
    PC2_GO_terms = if (is.null(res_PC2)) 0 else nrow(res_PC2$ego_df),
    PC2_KEGG_terms = if (is.null(res_PC2)) 0 else nrow(res_PC2$ekegg_df),
    stringsAsFactors = FALSE
  )
}

