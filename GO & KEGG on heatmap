run_cluster_enrichment <- function(
    cluster_number,
    cluster_gene_map,
    heatmap_gene_flow_audit,
    universe_entrez,
    output_root,
    pvalue_cutoff,
    qvalue_cutoff,
    top_terms_to_plot) {
  
  cluster_dir <- file.path(
    output_root,
    paste0("cluster_", cluster_number)
  )
  
  if (!dir.exists(cluster_dir)) {
    dir.create(cluster_dir, recursive = TRUE)
  }
  
  # Save every original heatmap row in this cluster, including excluded rows.
  all_heatmap_rows_here <- heatmap_gene_flow_audit %>%
    dplyr::filter(RowCluster == cluster_number) %>%
    dplyr::arrange(GeneName, GeneID)
  
  all_heatmap_gene_names_here <- all_heatmap_rows_here %>%
    dplyr::select(
      GeneID,
      GeneName,
      Status
    ) %>%
    dplyr::distinct()
  
  write.csv(
    all_heatmap_rows_here,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_ALL_heatmap_rows_with_mapping_status.csv"
      )
    ),
    row.names = FALSE
  )
  
  write.csv(
    all_heatmap_gene_names_here,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_ALL_heatmap_gene_names.csv"
      )
    ),
    row.names = FALSE
  )
  
  writeLines(
    unique(all_heatmap_gene_names_here$GeneName),
    con = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_ALL_heatmap_gene_names_one_per_line.txt"
      )
    )
  )
  
  # This is the exact cluster-specific enrichment foreground.
  usable_rows_here <- cluster_gene_map %>%
    dplyr::filter(RowCluster == cluster_number) %>%
    dplyr::distinct(
      GeneID,
      GeneName,
      RowCluster,
      MouseInput,
      MouseSymbol,
      ENTREZID
    ) %>%
    dplyr::arrange(MouseSymbol, ENTREZID, GeneName, GeneID)
  
  write.csv(
    usable_rows_here,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_EXACT_usable_heatmap_genes_for_GO_KEGG.csv"
      )
    ),
    row.names = FALSE
  )
  
  genes_here <- sort(unique(usable_rows_here$ENTREZID))
  
  exact_foreground_entrez_table <- data.frame(
    ENTREZID = genes_here,
    stringsAsFactors = FALSE
  )
  
  write.csv(
    exact_foreground_entrez_table,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_EXACT_GO_KEGG_foreground_EntrezIDs.csv"
      )
    ),
    row.names = FALSE
  )
  
  writeLines(
    genes_here,
    con = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_EXACT_GO_KEGG_foreground_EntrezIDs_one_per_line.txt"
      )
    )
  )
  
  exact_mouse_gene_input <- usable_rows_here %>%
    dplyr::select(
      MouseSymbol,
      ENTREZID,
      GeneID,
      GeneName,
      MouseInput
    ) %>%
    dplyr::distinct()
  
  write.csv(
    exact_mouse_gene_input,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_EXACT_GO_KEGG_input_with_gene_names.csv"
      )
    ),
    row.names = FALSE
  )
  
  cat("\n============================================================\n")
  cat("HEATMAP ROW CLUSTER", cluster_number, "\n")
  cat(
    "All heatmap Equ03 genes:",
    dplyr::n_distinct(all_heatmap_rows_here$GeneID),
    "\n"
  )
  cat(
    "Usable heatmap Equ03 genes:",
    dplyr::n_distinct(usable_rows_here$GeneID),
    "\n"
  )
  cat(
    "Unique mouse Entrez IDs submitted to GO and KEGG:",
    length(genes_here),
    "\n"
  )
  
  cat(
    "\nALL GENE NAMES IN HEATMAP CLUSTER ",
    cluster_number,
    " (including genes excluded from enrichment):\n",
    sep = ""
  )
  print(
    as.data.frame(all_heatmap_gene_names_here),
    row.names = FALSE
  )
  
  cat(
    "\nEXACT USABLE HEATMAP GENES MAPPED FOR GO/KEGG, CLUSTER ",
    cluster_number,
    ":\n",
    sep = ""
  )
  print(
    as.data.frame(exact_mouse_gene_input),
    row.names = FALSE
  )
  
  cat(
    "\nEXACT ENTREZ-ID VECTOR SUBMITTED AS gene= TO BOTH enrichGO() ",
    "AND enrichKEGG(), CLUSTER ",
    cluster_number,
    ":\n",
    sep = ""
  )
  print(
    exact_foreground_entrez_table,
    row.names = FALSE
  )
  
  if (length(genes_here) == 0) {
    warning(
      "Cluster ", cluster_number,
      " has no usable mapped mouse genes. Enrichment skipped."
    )
    
    return(NULL)
  }
  
  if (!all(genes_here %in% universe_entrez)) {
    stop(
      "Cluster ", cluster_number,
      " contains foreground Entrez IDs outside the universe."
    )
  }
  
  # GO Biological Process
  ego <- clusterProfiler::enrichGO(
    gene = genes_here,
    universe = universe_entrez,
    OrgDb = org.Mm.eg.db,
    keyType = "ENTREZID",
    ont = "BP",
    pAdjustMethod = "BH",
    pvalueCutoff = pvalue_cutoff,
    qvalueCutoff = qvalue_cutoff,
    readable = TRUE
  )
  
  ego_df <- add_rich_factor(as.data.frame(ego))
  
  # KEGG mouse pathways
  ekegg <- clusterProfiler::enrichKEGG(
    gene = genes_here,
    universe = universe_entrez,
    organism = "mmu",
    keyType = "ncbi-geneid",
    pvalueCutoff = pvalue_cutoff,
    pAdjustMethod = "BH",
    qvalueCutoff = qvalue_cutoff
  )
  
  if (nrow(as.data.frame(ekegg)) > 0) {
    ekegg <- clusterProfiler::setReadable(
      ekegg,
      OrgDb = org.Mm.eg.db,
      keyType = "ENTREZID"
    )
  }
  
  ekegg_df <- add_rich_factor(as.data.frame(ekegg))
  
  write.csv(
    ego_df,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_GO_BP_enrichment.csv"
      )
    ),
    row.names = FALSE
  )
  
  write.csv(
    ekegg_df,
    file = file.path(
      cluster_dir,
      paste0(
        "cluster_", cluster_number,
        "_KEGG_mouse_enrichment.csv"
      )
    ),
    row.names = FALSE
  )
  
  # GO RichFactor dotplot
  if (nrow(ego_df) > 0) {
    top_go <- ego_df %>%
      dplyr::arrange(dplyr::desc(RichFactor)) %>%
      utils::head(top_terms_to_plot) %>%
      add_rich_group()
    
    go_plot <- ggplot2::ggplot(
      top_go,
      ggplot2::aes(
        x = RichFactor,
        y = reorder(Description, RichFactor),
        color = RichGroup,
        size = Count
      )
    ) +
      ggplot2::geom_point(alpha = 0.9) +
      ggplot2::scale_color_manual(values = three_cols) +
      ggplot2::labs(
        title = paste0(
          "Heatmap cluster ", cluster_number,
          ": GO Biological Process"
        ),
        x = "Rich Factor",
        y = "GO term",
        color = "Rich Factor",
        size = "Gene Count"
      ) +
      clean_theme
    
    ggplot2::ggsave(
      filename = file.path(
        cluster_dir,
        paste0(
          "cluster_", cluster_number,
          "_GO_RichFactor_dotplot.pdf"
        )
      ),
      plot = go_plot,
      width = 8,
      height = 6
    )
  } else {
    cat(
      "Cluster ", cluster_number,
      ": no significant GO BP terms.\n",
      sep = ""
    )
  }
  
  # KEGG RichFactor barplot
  if (nrow(ekegg_df) > 0) {
    top_kegg <- ekegg_df %>%
      dplyr::arrange(dplyr::desc(RichFactor)) %>%
      utils::head(top_terms_to_plot) %>%
      add_rich_group()
    
    kegg_plot <- ggplot2::ggplot(
      top_kegg,
      ggplot2::aes(
        x = RichFactor,
        y = reorder(Description, RichFactor),
        fill = RichGroup
      )
    ) +
      ggplot2::geom_col(width = 0.75) +
      ggplot2::scale_fill_manual(values = three_cols) +
      ggplot2::labs(
        title = paste0(
          "Heatmap cluster ", cluster_number,
          ": KEGG pathways"
        ),
        x = "Rich Factor",
        y = "KEGG pathway",
        fill = "Rich Factor"
      ) +
      clean_theme
    
    ggplot2::ggsave(
      filename = file.path(
        cluster_dir,
        paste0(
          "cluster_", cluster_number,
          "_KEGG_RichFactor_barplot.pdf"
        )
      ),
      plot = kegg_plot,
      width = 8,
      height = 6
    )
  } else {
    cat(
      "Cluster ", cluster_number,
      ": no significant KEGG pathways.\n",
      sep = ""
    )
  }
  
  list(
    cluster = cluster_number,
    all_heatmap_gene_names = all_heatmap_gene_names_here,
    exact_foreground_table = usable_rows_here,
    exact_mouse_gene_input = exact_mouse_gene_input,
    foreground_entrez = genes_here,
    GO = ego,
    GO_table = ego_df,
    KEGG = ekegg,
    KEGG_table = ekegg_df
  )
}

enrichment_results <- lapply(
  clusters_to_analyse,
  function(cluster_number) {
    run_cluster_enrichment(
      cluster_number = cluster_number,
