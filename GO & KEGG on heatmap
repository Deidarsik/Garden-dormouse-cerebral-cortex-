is_valid_identifier <- function(x) {
  x <- trimws(as.character(x))
  
  !is.na(x) &
    x != "" &
    !(x %in% c(
      "-", ".", "NA", "na", "N/A", "n/a",
      "None", "none", "NULL", "null",
      "No", "no", "FALSE", "False", "false"
    ))
}

find_column_case_insensitive <- function(df, requested_name) {
  hit <- which(tolower(colnames(df)) == tolower(requested_name))
  
  if (length(hit) == 0) {
    return(NA_character_)
  }
  
  colnames(df)[hit[1]]
}

expand_identifier_column <- function(
    df,
    identifier_col,
    keep_cluster = FALSE) {
  
  required_cols <- "GeneID"
  
  if (keep_cluster) {
    required_cols <- c(required_cols, "RowCluster")
  }
  
  missing_cols <- setdiff(required_cols, colnames(df))
  
  if (length(missing_cols) > 0) {
    stop(
      "Missing required columns: ",
      paste(missing_cols, collapse = ", ")
    )
  }
  
  if (!identifier_col %in% colnames(df)) {
    stop("Identifier column not found: ", identifier_col)
  }
  
  if (keep_cluster) {
    out <- df %>%
      dplyr::transmute(
        GeneID = as.character(GeneID),
        RowCluster = as.integer(RowCluster),
        MouseInput = as.character(.data[[identifier_col]])
      )
  } else {
    out <- df %>%
      dplyr::transmute(
        GeneID = as.character(GeneID),
        MouseInput = as.character(.data[[identifier_col]])
      )
  }
  
  out %>%
    dplyr::filter(is_valid_identifier(MouseInput)) %>%
    tidyr::separate_rows(
      MouseInput,
      sep = "\\s*[,;|]+\\s*"
    ) %>%
    dplyr::mutate(
      MouseInput = trimws(MouseInput)
    ) %>%
    dplyr::filter(is_valid_identifier(MouseInput)) %>%
    dplyr::distinct()
}

map_mouse_identifiers <- function(ids, from_type) {
  ids <- unique(trimws(as.character(ids)))
  ids <- ids[is_valid_identifier(ids)]
  
  empty_result <- data.frame(
    MouseInput = character(),
    ENTREZID = character(),
    MouseSymbol = character(),
    stringsAsFactors = FALSE
  )
  
  if (length(ids) == 0) {
    return(empty_result)
  }
  
  supported_keytypes <- AnnotationDbi::keytypes(org.Mm.eg.db)
  
  if (!from_type %in% supported_keytypes) {
    stop(
      "Key type '", from_type,
      "' is not supported by org.Mm.eg.db.\nSupported key types include:\n",
      paste(supported_keytypes, collapse = ", ")
    )
  }
  
  mapped <- tryCatch(
    {
      suppressMessages(
        AnnotationDbi::select(
          org.Mm.eg.db,
          keys = ids,
          keytype = from_type,
          columns = unique(c("ENTREZID", "SYMBOL"))
        )
      )
    },
    error = function(e) {
      warning(
        "Mapping failed for key type ", from_type,
        ": ", conditionMessage(e)
      )
      
      return(NULL)
    }
  )
  
  if (is.null(mapped) || nrow(mapped) == 0) {
    return(empty_result)
  }
  
  input_values <- as.character(mapped[[from_type]])
  
  out <- data.frame(
    MouseInput = input_values,
    ENTREZID = as.character(mapped$ENTREZID),
    MouseSymbol = as.character(mapped$SYMBOL),
    stringsAsFactors = FALSE
  )
  
  out %>%
    dplyr::filter(
      is_valid_identifier(MouseInput),
      is_valid_identifier(ENTREZID)
    ) %>%
    dplyr::distinct()
}

add_rich_factor <- function(df) {
  if (nrow(df) == 0) {
    return(df)
  }
  
  df %>%
    dplyr::mutate(
      BackgroundTermGenes = as.numeric(
        sub("/.*", "", BgRatio)
      ),
      RichFactor = Count / BackgroundTermGenes
    )
}

add_rich_group <- function(df) {
  if (nrow(df) == 0) {
    return(df)
  }
  
  rich_breaks <- stats::quantile(
    df$RichFactor,
    probs = c(0, 1 / 3, 2 / 3, 1),
    na.rm = TRUE
  )
  
  if (length(unique(rich_breaks)) == 4) {
    return(
      df %>%
        dplyr::mutate(
          RichGroup = cut(
            RichFactor,
            breaks = rich_breaks,
            include.lowest = TRUE,
            labels = c("Low", "Medium", "High")
          )
        )
    )
  }
  
  distinct_values <- sort(unique(df$RichFactor))
  
  if (length(distinct_values) == 1) {
    df$RichGroup <- factor(
      rep("Low", nrow(df)),
      levels = c("Low", "Medium", "High")
    )
  } else if (length(distinct_values) == 2) {
    df$RichGroup <- factor(
      ifelse(
        df$RichFactor == min(distinct_values),
        "Low",
        "High"
      ),
      levels = c("Low", "Medium", "High")
    )
  } else {
    df$RichGroup <- factor(
      c("Low", "Medium", "High")[
        dplyr::ntile(
          rank(df$RichFactor, ties.method = "first"),
          3
        )
      ],
      levels = c("Low", "Medium", "High")
    )
  }
  
  df
}

