#!/usr/bin/env Rscript

###############################################################################
# GO_KEGG_heatmap_clusters_strict.R
#
# PURPOSE
#   Run GO Biological Process and KEGG enrichment separately for row cluster 1
#   and row cluster 2 from the heatmap.
#
# STRICT FOREGROUND RULE
#   Cluster 1 enrichment = only usable mouse-mapped genes originating from
#                          heatmap row cluster 1.
#   Cluster 2 enrichment = only usable mouse-mapped genes originating from
#                          heatmap row cluster 2.
#
# A heatmap gene is usable for enrichment only when:
#   1. it has a non-empty mouse ortholog identifier;
#   2. that identifier maps to a mouse Entrez ID in org.Mm.eg.db; and
#   3. that Entrez ID is present in the mapped tested-gene universe.
#
# The script stops if:
#   - the cluster-assignment file does not exactly match the heatmap rows;
#   - clusters 1 and 2 do not together contain all heatmap genes;
#   - one Equ03 gene is assigned to more than one row cluster;
#   - an enrichment source gene does not belong to its stated heatmap cluster;
#   - a mapped foreground gene is unexpectedly absent from the universe.
###############################################################################

