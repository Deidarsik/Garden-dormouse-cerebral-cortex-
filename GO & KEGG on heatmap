    stop(
      "Manual mouse ortholog column not found: ",
      manual_mouse_ortholog_col,
      "\nAvailable annotation columns:\n",
      paste(colnames(gene_annotations), collapse = ", ")
    )
  }
  
  if (is.null(manual_mouse_key_type)) {
    recognised_row <- candidate_specs %>%
      dplyr::filter(
        tolower(ActualColumn) == tolower(selected_mouse_col)
      )
    
    if (nrow(recognised_row) == 0) {
      stop(
        "A manual ortholog column was supplied, but its key type was not.\n",
        "Also set manual_mouse_key_type, for example SYMBOL, ENSEMBL, ",
        "or ENTREZID."
      )
    }
    
    selected_key_type <- recognised_row$KeyType[1]
  } else {
    selected_key_type <- manual_mouse_key_type
  }
  
  candidate_selection_table <- data.frame(
    ActualColumn = selected_mouse_col,
    KeyType = selected_key_type,
    HeatmapGenesWithValidInput = NA_integer_,
    HeatmapGenesMappedToEntrez = NA_integer_,
    UniqueMouseEntrez = NA_integer_,
    stringsAsFactors = FALSE
  )
  
} else {
  if (nrow(candidate_specs) == 0) {
    stop(
      "No recognised mouse ortholog identifier columns were found.\n",
      "Set manual_mouse_ortholog_col and manual_mouse_key_type near the ",
      "top of the script.\nAvailable annotation columns:\n",
      paste(colnames(gene_annotations), collapse = ", ")
    )
  }
  
  candidate_evaluations <- lapply(
    seq_len(nrow(candidate_specs)),
    function(i) {
      col_here <- candidate_specs$ActualColumn[i]
      key_here <- candidate_specs$KeyType[i]
      
      long_here <- expand_identifier_column(
        heatmap_annotation_base,
        identifier_col = col_here,
        keep_cluster = TRUE
      )
      
      map_here <- map_mouse_identifiers(
        long_here$MouseInput,
        from_type = key_here
      )
      
      mapped_genes_here <- long_here %>%
        dplyr::inner_join(
          map_here,
          by = "MouseInput"
        )
      
      data.frame(
        ActualColumn = col_here,
        KeyType = key_here,
        Priority = candidate_specs$Priority[i],
        HeatmapGenesWithValidInput = dplyr::n_distinct(long_here$GeneID),
        HeatmapGenesMappedToEntrez = dplyr::n_distinct(mapped_genes_here$GeneID),
        UniqueMouseEntrez = dplyr::n_distinct(mapped_genes_here$ENTREZID),
        stringsAsFactors = FALSE
      )
    }
  )
  
  candidate_selection_table <- dplyr::bind_rows(candidate_evaluations) %>%
    dplyr::arrange(
      dplyr::desc(HeatmapGenesMappedToEntrez),
      dplyr::desc(UniqueMouseEntrez),
      Priority
    )
  
  if (
    nrow(candidate_selection_table) == 0 ||
    max(candidate_selection_table$HeatmapGenesMappedToEntrez) == 0
  ) {
    stop(
      "None of the recognised annotation columns mapped any heatmap genes ",
      "to mouse Entrez IDs."
    )
  }
  
  selected_mouse_col <- candidate_selection_table$ActualColumn[1]
  selected_key_type <- candidate_selection_table$KeyType[1]
}

