#!/usr/bin/env Rscript
library(ggplot2)

x <- seq(0, 20, length.out = 2000)

high_temp     <- 37
low_temp      <- 5
high_duration <- 2.4
low_duration  <- 5.4
period        <- high_duration + low_duration

transition <- 0.15   # width of each smooth edge in days

t_mod <- x %% period

y <- numeric(length(x))

for (i in seq_along(t_mod)) {
  t <- t_mod[i]
  
  if (t < (high_duration - transition)) {
    # flat high plateau
    y[i] <- high_temp
    
  } else if (t < high_duration) {
    # smooth fall from high to low
    u <- (t - (high_duration - transition)) / transition
    s <- 0.5 - 0.5 * cos(pi * u)   # smooth cosine easing
    y[i] <- high_temp + (low_temp - high_temp) * s
    
  } else if (t < (period - transition)) {
    # flat low plateau
    y[i] <- low_temp
    
  } else {
    # smooth rise from low to high
    u <- (t - (period - transition)) / transition
    s <- 0.5 - 0.5 * cos(pi * u)
    y[i] <- low_temp + (high_temp - low_temp) * s
  }
}

df <- data.frame(Days = x, Temperature = y)

p <- ggplot(df, aes(x = Days, y = Temperature)) +
  geom_line(linewidth = 1) +
  scale_x_continuous(
    breaks = seq(0, 20, by = 5),
    limits = c(0, 20)
  ) +
  scale_y_continuous(
    breaks = c(4, 20, 37),
    limits = c(4, 37)
  ) +
  labs(x = "Days", y = "Body Temperature (°C)") +
  theme_classic(base_size = 35) +
  theme(
    axis.line   = element_line(color = "black", linewidth = 1.5),
    axis.text.x = element_text(size = rel(1.5)),
    axis.text.y = element_text(size = rel(1.5))
  )

ggsave("torpor_arousal_cycle.pdf", plot = p, width = 12, height = 8, device = "pdf")
ggsave("torpor_arousal_cycle.png", plot = p, width = 12, height = 8, dpi = 300)




