#############################

wb <- openxlsx::createWorkbook()

openxlsx::addWorksheet(wb, "all_heatmap_genes")
openxlsx::writeDataTable(wb, "all_heatmap_genes", all_heatmap_gene_table)

openxlsx::addWorksheet(wb, "gene_group_values")
openxlsx::writeDataTable(wb, "gene_group_values", gene_group_values)

openxlsx::addWorksheet(wb, "row_cluster_annotation")
openxlsx::writeDataTable(wb, "row_cluster_annotation", cluster_assignment_df)

openxlsx::addWorksheet(wb, "row_cluster_counts")
openxlsx::writeDataTable(wb, "row_cluster_counts", cluster_summary_df)

openxlsx::addWorksheet(wb, "warm_vs_cold_sig")
openxlsx::writeDataTable(wb, "warm_vs_cold_sig", warm_vs_cold_sig)

openxlsx::saveWorkbook(wb, xlsx_output_path, overwrite = TRUE)

cat("Workbook saved:", xlsx_output_path, "\n")

