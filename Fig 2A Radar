cat("This script plotted ALL heatmap genes.\n")
cat("Warm-vs-cold FDR cutoff:", heatmap_fdr_cutoff, "\n")
cat("Initial heatmap genes passing FDR:", length(heatmap_gene_ids), "\n")
cat("Final heatmap genes after z-score finite filtering:", length(heatmap_gene_ids_final), "\n")
cat("Genes plotted on radar:", n_genes_plotted, "\n")
cat("Max genes cap:", ifelse(is.null(max_genes_to_plot), "NULL / no cap", max_genes_to_plot), "\n")
cat("Text scale:", text_scale, "\n")
