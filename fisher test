      gene_comparison$
      logFC_sex_adjusted_TL_AE
  ) < 0

gene_comparison$
  Sex_adjusted_significant_both_FDR_0.01 <-
  gene_comparison$
  FDR_sex_adjusted_TE_TL <
  primary_fdr_cutoff &
  gene_comparison$
  FDR_sex_adjusted_TL_AE <
  primary_fdr_cutoff

gene_comparison$
  Sex_adjusted_significant_both_FDR_0.05 <-
  gene_comparison$
  FDR_sex_adjusted_TE_TL <
  sensitivity_fdr_cutoff &
  gene_comparison$
  FDR_sex_adjusted_TL_AE <
  sensitivity_fdr_cutoff

gene_comparison$
  Reversal_recovered_at_FDR_0.05 <-
  gene_comparison$
  Sex_adjusted_significant_both_FDR_0.05 &
