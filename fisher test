read_deg_table <- function(
    directory,
    contrast_name
) {
  file_path <- file.path(
    directory,
    paste0(
      contrast_name,
      "_differential_expression.txt"
    )
  )
  
  if (!file.exists(file_path)) {
    stop(
      "Required DEG table was not found:\n",
      file_path
    )
  }
  
  result <- read.table(
    file_path,
    header = TRUE,
    sep = "\t",
    stringsAsFactors = FALSE,
    check.names = FALSE,
    quote = "",
    comment.char = ""
  )
  
  required_columns <- c(
    "GeneID",
    "logFC",
    "FDR"
  )
  
  missing_columns <- setdiff(
    required_columns,
    colnames(result)
  )
  
  if (length(missing_columns) > 0) {
    stop(
      "The file ",
      basename(file_path),
      " is missing the following columns: ",
      paste(missing_columns, collapse = ", ")
    )
  }
  
  result$GeneID <- trimws(
    as.character(result$GeneID)
  )
  
  result$logFC <- as.numeric(
    result$logFC
  )
  
  result$FDR <- as.numeric(
    result$FDR
  )
  
  result <- result[
    !is.na(result$GeneID) &
      result$GeneID != "",
    ,
    drop = FALSE
  ]
  
  if (anyDuplicated(result$GeneID)) {
    duplicated_ids <- unique(
      result$GeneID[
        duplicated(result$GeneID)
      ]
    )
    
    stop(
      "Duplicated GeneIDs were found in ",
      basename(file_path),
      ". Examples: ",
      paste(
        head(duplicated_ids, 20),
        collapse = ", "
      )
    )
  }
  
  result
}


check_same_universe <- function(
    table_1,
    table_2,
    label_1,
    label_2
) {
  if (!setequal(table_1$GeneID, table_2$GeneID)) {
    stop(
      "The tested-gene universes differ between ",
      label_1,
      " and ",
      label_2,
      "."
    )
  }
  
  invisible(TRUE)
}


get_significant_ids <- function(
    result_table,
    fdr_threshold
) {
  unique(
    result_table$GeneID[
      !is.na(result_table$FDR) &
        result_table$FDR < fdr_threshold
    ]
  )
}


get_directional_reversal_sets <- function(
    results_list,
    fdr_threshold
) {
  te_tl <- results_list[["TE_vs_TL"]]
  tl_ae <- results_list[["TL_vs_AE"]]
  
  check_same_universe(
    te_tl,
    tl_ae,
    "TE_vs_TL",
    "TL_vs_AE"
  )
  
  common_gene_ids <- intersect(
    te_tl$GeneID,
    tl_ae$GeneID
  )
  
  te_tl <- te_tl[
    match(
      common_gene_ids,
      te_tl$GeneID
    ),
    ,
    drop = FALSE
  ]
  
  tl_ae <- tl_ae[
    match(
      common_gene_ids,
      tl_ae$GeneID
    ),
    ,
    drop = FALSE
  ]
  
  significant_te_tl <- get_significant_ids(
    te_tl,
    fdr_threshold
  )
  
  significant_tl_ae <- get_significant_ids(
    tl_ae,
    fdr_threshold
  )
  
  shared_significant <- intersect(
    significant_te_tl,
    significant_tl_ae
  )
  
  te_tl_negative <- te_tl$GeneID[
    !is.na(te_tl$FDR) &
      te_tl$FDR < fdr_threshold &
      !is.na(te_tl$logFC) &
      te_tl$logFC < 0
  ]
  
  te_tl_positive <- te_tl$GeneID[
    !is.na(te_tl$FDR) &
      te_tl$FDR < fdr_threshold &
      !is.na(te_tl$logFC) &
      te_tl$logFC > 0
  ]
  
  tl_ae_negative <- tl_ae$GeneID[
    !is.na(tl_ae$FDR) &
      tl_ae$FDR < fdr_threshold &
      !is.na(tl_ae$logFC) &
      tl_ae$logFC < 0
  ]
  
  tl_ae_positive <- tl_ae$GeneID[
    !is.na(tl_ae$FDR) &
      tl_ae$FDR < fdr_threshold &
      !is.na(tl_ae$logFC) &
      tl_ae$logFC > 0
  ]
  
  # Main biological reversal:
  # higher in TL than TE, followed by higher in TL than AE.
  #
  # Chronologically:
  # increased from TE to TL, then decreased from TL to AE.
  torpor_up_arousal_down <- intersect(
    te_tl_negative,
    tl_ae_positive
  )
  
  # Inverse biological reversal:
  # lower in TL than TE, followed by lower in TL than AE.
  #
  # Chronologically:
  # decreased from TE to TL, then increased from TL to AE.
  torpor_down_arousal_up <- intersect(
    te_tl_positive,
    tl_ae_negative
  )
  
  all_reversal_genes <- union(
    torpor_up_arousal_down,
    torpor_down_arousal_up
  )
  
  shared_same_sign <- setdiff(
    shared_significant,
    all_reversal_genes
  )
  
  list(
    Background_gene_ids = common_gene_ids,
    Background_N = length(common_gene_ids),
    
    Significant_TE_TL = significant_te_tl,
    Significant_TL_AE = significant_tl_ae,
    Shared_significant = shared_significant,
    
    TE_TL_negative = te_tl_negative,
    TE_TL_positive = te_tl_positive,
    TL_AE_negative = tl_ae_negative,
    TL_AE_positive = tl_ae_positive,
    
    Torpor_up_arousal_down =
      torpor_up_arousal_down,
    
    Torpor_down_arousal_up =
      torpor_down_arousal_up,
    
    All_reversal_genes =
      all_reversal_genes,
    
    Shared_same_sign =
      shared_same_sign
  )
}


fisher_overlap_test <- function(
    gene_set_1,
    gene_set_2,
    background_n
) {
  gene_set_1 <- unique(
    gene_set_1
  )
  
  gene_set_2 <- unique(
    gene_set_2
  )
  
  observed_overlap <- length(
    intersect(
      gene_set_1,
      gene_set_2
    )
  )
  
  set_1_only <- length(gene_set_1) -
    observed_overlap
  
  set_2_only <- length(gene_set_2) -
    observed_overlap
  
  neither <- background_n -
    observed_overlap -
    set_1_only -
    set_2_only
  
  contingency_table <- matrix(
    c(
      observed_overlap,
      set_1_only,
      set_2_only,
      neither
    ),
    nrow = 2,
    byrow = TRUE,
    dimnames = list(
      c(
        "In_set_1",
        "Not_in_set_1"
      ),
      c(
        "In_set_2",
        "Not_in_set_2"
      )
    )
  )
  
  if (any(contingency_table < 0)) {
    stop(
      "The Fisher contingency table contains a negative cell."
    )
  }
  
  fisher_result <- fisher.test(
    contingency_table,
    alternative = "greater"
  )
  
  expected_overlap <- (
    length(gene_set_1) *
      length(gene_set_2)
  ) / background_n
  
  list(
    Set_1_size = length(gene_set_1),
    Set_2_size = length(gene_set_2),
    Observed_overlap = observed_overlap,
    Expected_overlap = expected_overlap,
    Odds_ratio = unname(
      fisher_result$estimate
    ),
    P_value = fisher_result$p.value,
    Contingency_table = contingency_table
  )
}


run_directional_fisher <- function(
    results_list,
    analysis_name,
    fdr_threshold
) {
  reversal_sets <- get_directional_reversal_sets(
    results_list = results_list,
    fdr_threshold = fdr_threshold
  )
  
  main_test <- fisher_overlap_test(
    gene_set_1 =
      reversal_sets$TE_TL_negative,
    
    gene_set_2 =
      reversal_sets$TL_AE_positive,
    
    background_n =
      reversal_sets$Background_N
  )
  
  inverse_test <- fisher_overlap_test(
    gene_set_1 =
      reversal_sets$TE_TL_positive,
    
    gene_set_2 =
      reversal_sets$TL_AE_negative,
    
    background_n =
      reversal_sets$Background_N
  )
  
  raw_p_values <- c(
    main_test$P_value,
    inverse_test$P_value
  )
  
  within_analysis_q_values <- p.adjust(
    raw_p_values,
    method = "BH"
  )
  
  summary_table <- data.frame(
    Analysis = analysis_name,
    
    FDR_threshold =
      fdr_threshold,
    
    Background_genes =
      reversal_sets$Background_N,
    
    Direction = c(
      paste0(
        "Increased_TE_to_TL_then_",
        "decreased_TL_to_AE"
      ),
      paste0(
        "Decreased_TE_to_TL_then_",
        "increased_TL_to_AE"
      )
    ),
    
    TE_TL_directional_set_size = c(
      main_test$Set_1_size,
      inverse_test$Set_1_size
    ),
    
    TL_AE_directional_set_size = c(
      main_test$Set_2_size,
      inverse_test$Set_2_size
    ),
    
    Observed_overlap = c(
      main_test$Observed_overlap,
      inverse_test$Observed_overlap
    ),
    
    Expected_overlap = c(
      main_test$Expected_overlap,
      inverse_test$Expected_overlap
    ),
    
    Odds_ratio = c(
      main_test$Odds_ratio,
      inverse_test$Odds_ratio
    ),
    
    Fisher_P_value =
      raw_p_values,
    
    BH_Q_value_within_analysis_2_tests =
      within_analysis_q_values,
    
    stringsAsFactors = FALSE
  )
  
  list(
    sets = reversal_sets,
    main_test = main_test,
    inverse_test = inverse_test,
    summary = summary_table
  )
}


