    ),
    format_reversal_result(
      sex_adjusted_table_2$Reversed_shared_DEGs[i],
      sex_adjusted_table_2$Percent_reversed[i]
    )
  )
}

write_tab_file(
  table_2_word_layout,
  file.path(
